.pg-stars-md{animation:twinkle-b 5s ease-in-out infinite alternate;box-shadow:95px 65px 0 .75px rgba(255,255,255,.75),440px 48px 0 .75px rgba(255,255,255,.8),810px 80px 0 .75px rgba(255,255,255,.65),1130px 90px 0 .75px rgba(255,255,255,.7),60px 265px 0 .75px rgba(255,255,255,.65),380px 250px 0 .75px rgba(255,255,255,.7),690px 270px 0 .75px rgba(255,255,255,.75),1020px 260px 0 .75px rgba(255,255,255,.65),75px 430px 0 .75px rgba(255,255,255,.7),405px 395px 0 .75px rgba(255,255,255,.65),720px 410px 0 .75px rgba(255,255,255,.75),1045px 420px 0 .75px rgba(255,255,255,.7),200px 580px 0 .75px rgba(255,255,255,.75),515px 590px 0 .75px rgba(255,255,255,.65),835px 610px 0 .75px rgba(255,255,255,.7),250px 720px 0 .75px rgba(255,255,255,.75),750px 680px 0 .75px rgba(255,255,255,.7),1070px 695px 0 .75px rgba(255,255,255,.65),155px 150px 0 .75px rgba(255,210,63,.5),960px 140px 0 .75px rgba(255,210,63,.45),480px 200px 0 .75px rgba(155,89,240,.4),860px 490px 0 .75px rgba(79,209,232,.35)}
.pg-stars-lg{animation:twinkle-c 7s ease-in-out infinite alternate;box-shadow:120px 95px 0 1.25px rgba(255,255,255,.8),590px 140px 0 1.25px rgba(255,255,255,.75),1060px 75px 0 1.25px rgba(255,255,255,.8),165px 290px 0 1.25px rgba(255,255,255,.75),650px 280px 0 1.25px rgba(255,255,255,.8),1120px 290px 0 1.25px rgba(255,255,255,.75),330px 490px 0 1.25px rgba(255,255,255,.8),780px 500px 0 1.25px rgba(255,255,255,.7),90px 440px 0 1.25px rgba(255,255,255,.75),390px 640px 0 1.25px rgba(255,255,255,.8),860px 650px 0 1.25px rgba(255,255,255,.7),210px 730px 0 1.25px rgba(255,255,255,.8),730px 760px 0 1.25px rgba(255,255,255,.75),510px 170px 0 1.25px rgba(255,210,63,.55),940px 440px 0 1.25px rgba(255,210,63,.5),700px 350px 0 1.25px rgba(155,89,240,.45),260px 560px 0 1.25px rgba(79,209,232,.4)}

/* ═══ SHOOTING STARS ═══ */
.pg-shoot{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.ps{position:absolute;width:80px;height:1px;background:linear-gradient(90deg,rgba(255,255,255,0),rgba(255,255,255,.7),rgba(255,255,255,0));border-radius:1px;opacity:0}
.ps-1{top:12%;animation:shoot-lr 6s linear 4s infinite}
.ps-2{top:28%;animation:shoot-rl 7s linear 8s infinite}
.ps-3{top:45%;animation:shoot-lr 5s linear 13s infinite}
.ps-4{top:62%;animation:shoot-rl 6s linear 18s infinite}
.ps-5{top:78%;animation:shoot-lr 7s linear 22s infinite}
.ps-6{top:35%;animation:shoot-rl 5s linear 26s infinite}

/* ═══ FLOATING WORDS ═══ */
.drift{position:fixed;font-size:clamp(4rem,12vw,10rem);font-weight:900;text-transform:uppercase;color:rgba(255,255,255,.04);letter-spacing:10px;white-space:nowrap;pointer-events:none;user-select:none;z-index:0}
.drift-1{top:5%;left:0;animation:drift-l 75s ease-in-out infinite alternate}
.drift-2{top:18%;right:-8%;animation:drift-r 85s ease-in-out infinite alternate}
.drift-3{top:32%;left:-4%;animation:drift-l 90s ease-in-out infinite alternate}
.drift-4{top:46%;right:-2%;animation:drift-r 70s ease-in-out infinite alternate}
.drift-5{top:60%;left:3%;animation:drift-l 80s ease-in-out infinite alternate}
.drift-6{top:74%;right:0;animation:drift-r 65s ease-in-out infinite alternate}
.drift-7{top:88%;left:-5%;animation:drift-l 78s ease-in-out infinite alternate}

/* ═══ NAV ═══ */
.nav{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(10,10,18,.65);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid rgba(123,47,242,.1)}
.nav-inner{max-width:1180px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:72px}
.logo{display:flex;align-items:center;gap:10px;font-weight:800;font-size:1.2rem;z-index:201}
.logo-icon{display:inline-flex;align-items:center;justify-content:center;width:38px;height:38px;background:linear-gradient(135deg,var(--purple),var(--orange));border-radius:11px;font-weight:900;font-size:1.1rem;color:#fff}
.logo-word{color:#fff;letter-spacing:-.3px}
.nav-links{display:flex;align-items:center;gap:32px;font-size:.925rem;font-weight:500}
.nav-links a{color:rgba(255,255,255,.6);transition:color .25s}
.nav-links a:hover,.nav-links a.active{color:#fff}
.nav-btn{background:linear-gradient(135deg,var(--purple),var(--orange));color:#fff!important;padding:10px 24px;border-radius:10px;font-weight:700;transition:transform .3s,box-shadow .3s;box-shadow:0 0 18px rgba(123,47,242,.3)}
.nav-btn:hover{transform:translateY(-2px) scale(1.05);box-shadow:0 0 30px rgba(123,47,242,.5)}
.burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px;z-index:201}
.burger span{display:block;width:24px;height:2px;background:#fff;border-radius:2px}

/* ═══ GLOW TEXT ═══ */
.gl-gold,.gl-cyan,.gl-purple,.gl-orange{-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;font-weight:600}
.gl-gold{background-image:linear-gradient(135deg,#FFD23F,#F5C842);filter:drop-shadow(0 0 12px rgba(255,210,63,.3))}
.gl-cyan{background-image:linear-gradient(135deg,#4FD1E8,#38B5CC);filter:drop-shadow(0 0 12px rgba(79,209,232,.3))}
.gl-purple{background-image:linear-gradient(135deg,#7B2FF2,#9B59F0);filter:drop-shadow(0 0 12px rgba(123,47,242,.3))}
.gl-orange{background-image:linear-gradient(135deg,#FF6B35,#FF8F5E);filter:drop-shadow(0 0 12px rgba(255,107,53,.3))}

/* ═══ S2 — HERO ═══ */
.hero{position:relative;z-index:1;min-height:100vh;min-height:100svh;display:flex;align-items:center;overflow:hidden;padding:120px 0 80px;background:linear-gradient(170deg,var(--bg) 0%,#0c0a1e 30%,#0f1230 55%,#0a0818 100%)}
.hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.hero-copy{position:relative;z-index:2}
.eyebrow{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:var(--cyan);margin-bottom:20px;opacity:0;animation:rise .8s cubic-bezier(.22,1,.36,1) .1s forwards}
.hero-h1{font-size:clamp(2.2rem,5vw,3.4rem);font-weight:900;color:#fff;letter-spacing:1px;margin-bottom:36px;line-height:1.1;text-shadow:0 0 60px rgba(123,47,242,.15);opacity:0;animation:rise .8s cubic-bezier(.22,1,.36,1) .2s forwards}
.body-text{font-size:1.05rem;line-height:1.85;color:rgba(255,255,255,.6);margin-bottom:20px;opacity:0;animation:rise .8s cubic-bezier(.22,1,.36,1) .35s forwards}
.body-text:nth-of-type(3){animation-delay:.45s}
.body-text:nth-of-type(4){animation-delay:.55s}
.mission-line{position:relative;display:inline-block;font-size:clamp(1.3rem,3vw,1.8rem);font-weight:800;color:#fff;margin-top:36px;letter-spacing:-.5px;opacity:0;animation:rise .8s cubic-bezier(.22,1,.36,1) .65s forwards}
.mission-underline{position:absolute;bottom:-8px;left:0;width:100%;height:3px;border-radius:2px;background:linear-gradient(90deg,transparent,var(--gold),var(--orange),var(--gold),transparent);background-size:200% 100%;animation:shimmer 3s linear infinite}

/* ═══ GALAXY ORB ═══ */
.hero-orb-wrap{display:flex;align-items:center;justify-content:center;position:relative;z-index:2}
.galaxy{position:relative;width:520px;height:520px}
.galaxy-core{position:absolute;top:50%;left:50%;width:240px;height:240px;transform:translate(-50%,-50%);border-radius:50%;background:radial-gradient(circle,rgba(255,210,63,.12) 0%,rgba(123,47,242,.25) 30%,rgba(13,27,62,.6) 60%,rgba(10,10,18,.9) 100%);box-shadow:0 0 60px rgba(123,47,242,.2),0 0 120px rgba(79,209,232,.08),inset 0 0 80px rgba(123,47,242,.15);animation:core-pulse 8s ease-in-out infinite}
.core-inner{position:absolute;inset:25%;border-radius:50%;background:radial-gradient(circle,rgba(255,210,63,.2) 0%,rgba(123,47,242,.12) 50%,transparent 100%);filter:blur(8px)}
.orbit-ring{position:absolute;top:50%;left:50%;border-radius:50%;border:1px solid transparent}
.ring-1{width:340px;height:340px;margin-top:-170px;margin-left:-170px;border-color:rgba(79,209,232,.15);box-shadow:0 0 12px rgba(79,209,232,.1),inset 0 0 12px rgba(79,209,232,.05);animation:spin-cw 30s linear infinite}
.ring-2{width:420px;height:420px;margin-top:-210px;margin-left:-210px;border-color:rgba(123,47,242,.12);box-shadow:0 0 10px rgba(123,47,242,.08),inset 0 0 10px rgba(123,47,242,.04);animation:spin-ccw 45s linear infinite}
.ring-3{width:500px;height:500px;margin-top:-250px;margin-left:-250px;border-color:rgba(79,209,232,.08);box-shadow:0 0 8px rgba(79,209,232,.06);animation:spin-cw 60s linear infinite}

/* Radial particles */
.rp{position:absolute;top:50%;left:50%;width:3px;height:3px;border-radius:50%;background:rgba(255,255,255,.6);animation:radial-drift var(--rd-dur,8s) linear infinite;animation-delay:var(--rd-del,0s)}
.rp-1{--rd-end:translate(120px,-80px);--rd-dur:7s;--rd-del:0s}
.rp-2{--rd-end:translate(-100px,-110px);--rd-dur:9s;--rd-del:1s;background:rgba(79,209,232,.5)}
.rp-3{--rd-end:translate(140px,60px);--rd-dur:8s;--rd-del:2s}
.rp-4{--rd-end:translate(-130px,90px);--rd-dur:10s;--rd-del:3s;background:rgba(255,210,63,.5)}
.rp-5{--rd-end:translate(60px,140px);--rd-dur:7.5s;--rd-del:1.5s}
.rp-6{--rd-end:translate(-50px,-140px);--rd-dur:8.5s;--rd-del:.5s;background:rgba(123,47,242,.5)}
.rp-7{--rd-end:translate(110px,-120px);--rd-dur:9.5s;--rd-del:4s}
.rp-8{--rd-end:translate(-140px,30px);--rd-dur:7s;--rd-del:2.5s;background:rgba(79,209,232,.5)}
.rp-9{--rd-end:translate(30px,-150px);--rd-dur:11s;--rd-del:5s}
.rp-10{--rd-end:translate(-80px,130px);--rd-dur:8s;--rd-del:3.5s;background:rgba(255,210,63,.5)}
.rp-11{--rd-end:translate(150px,20px);--rd-dur:6.5s;--rd-del:1s}
.rp-12{--rd-end:translate(-20px,155px);--rd-dur:10s;--rd-del:6s;background:rgba(123,47,242,.5)}
.rp-13{--rd-end:translate(90px,110px);--rd-dur:8.5s;--rd-del:2s;background:rgba(79,209,232,.4)}
.rp-14{--rd-end:translate(-110px,-60px);--rd-dur:7.5s;--rd-del:4.5s}
.rp-15{--rd-end:translate(50px,-130px);--rd-dur:9s;--rd-del:7s;background:rgba(255,210,63,.4)}
.rp-16{--rd-end:translate(-60px,120px);--rd-dur:10.5s;--rd-del:3s;background:rgba(123,47,242,.4)}

/* ═══ SECTION HEADINGS ═══ */
.sec-h{text-align:center;font-size:clamp(1.6rem,4vw,2.6rem);font-weight:900;color:#fff;letter-spacing:1px;margin-bottom:12px;text-shadow:0 0 50px rgba(123,47,242,.12)}
.sec-h-gold{background:linear-gradient(135deg,var(--gold),var(--orange));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;filter:drop-shadow(0 0 16px rgba(255,210,63,.25))}
.sec-sub{text-align:center;font-size:1rem;color:rgba(255,255,255,.5);margin-bottom:56px}
.sec-sub-cyan{color:var(--cyan)}

/* ═══ S3 — PATHS ═══ */
.paths{position:relative;z-index:1;padding:120px 0;background:linear-gradient(180deg,#0a0818 0%,#0e1028 50%,#0a0818 100%)}
.path-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;margin-bottom:48px}
.path-card{background:var(--glass);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(123,47,242,.12);border-radius:18px;padding:32px 24px;text-align:center;transition:transform .3s,box-shadow .3s,border-color .3s}
.path-card:hover{transform:translateY(-5px) scale(1.02);box-shadow:0 0 36px rgba(123,47,242,.15);border-color:rgba(123,47,242,.3)}
.path-badge{display:inline-block;padding:5px 16px;border-radius:20px;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:16px}
.badge-gold{background:rgba(255,210,63,.12);color:var(--gold);border:1px solid rgba(255,210,63,.25)}
.badge-orange{background:rgba(255,107,53,.12);color:var(--orange);border:1px solid rgba(255,107,53,.25)}
.badge-purple{background:rgba(123,47,242,.12);color:var(--purple-lt);border:1px solid rgba(123,47,242,.25)}
.badge-cyan{background:rgba(79,209,232,.12);color:var(--cyan);border:1px solid rgba(79,209,232,.25)}
.path-icon{font-size:2rem;margin-bottom:12px}
.path-card h3{font-size:1rem;font-weight:800;color:#fff;letter-spacing:.5px;margin-bottom:16px}
.path-card li{font-size:.88rem;color:rgba(255,255,255,.5);padding:5px 0;border-bottom:1px solid rgba(255,255,255,.04)}
.path-card li:last-child{border-bottom:none}
.paths-tagline{text-align:center;font-style:italic;font-size:1.05rem;background:linear-gradient(135deg,var(--gold),var(--orange));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;filter:drop-shadow(0 0 10px rgba(255,210,63,.2))}

/* ═══ S4 — KWC ═══ */
.kwc{position:relative;z-index:1;padding:120px 0;background:linear-gradient(180deg,#0a0818 0%,var(--bg-mid) 50%,#0a0818 100%)}
.kwc-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
.kwc-copy p{font-size:1.05rem;line-height:1.85;color:rgba(255,255,255,.6);margin-bottom:20px}

/* KWC orbits visual */
.kwc-visual{display:flex;justify-content:center;align-items:center}
.kwc-orbits{position:relative;width:340px;height:340px}
.kwc-ring{position:absolute;top:50%;left:50%;border-radius:50%;border:1.5px solid transparent}
.kwc-ring-outer{width:320px;height:320px;margin-top:-160px;margin-left:-160px;border-color:rgba(123,47,242,.25);box-shadow:0 0 16px rgba(123,47,242,.1),inset 0 0 16px rgba(123,47,242,.05);animation:kwc-orbit 25s linear infinite}
.kwc-ring-mid{width:220px;height:220px;margin-top:-110px;margin-left:-110px;border-color:rgba(255,107,53,.25);box-shadow:0 0 14px rgba(255,107,53,.1),inset 0 0 14px rgba(255,107,53,.05);animation:kwc-orbit 18s linear infinite reverse}
.kwc-ring-inner{width:120px;height:120px;margin-top:-60px;margin-left:-60px;border-color:rgba(255,210,63,.25);box-shadow:0 0 12px rgba(255,210,63,.1),inset 0 0 12px rgba(255,210,63,.05);animation:kwc-orbit 12s linear infinite}
.kwc-center-dot{position:absolute;top:50%;left:50%;width:8px;height:8px;margin:-4px 0 0 -4px;border-radius:50%;background:rgba(255,255,255,.3);box-shadow:0 0 12px rgba(255,255,255,.2)}
.kwc-label{position:absolute;font-size:.6rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:rgba(255,255,255,.4)}
.kwc-label-outer{top:-18px;left:50%;transform:translateX(-50%);color:rgba(123,47,242,.6)}
.kwc-label-mid{top:-16px;left:50%;transform:translateX(-50%);color:rgba(255,107,53,.6)}
.kwc-label-inner{top:-14px;left:50%;transform:translateX(-50%);color:rgba(255,210,63,.6)}
.kwc-dot{position:absolute;width:5px;height:5px;border-radius:50%;top:50%;left:50%;margin:-2.5px 0 0 -2.5px}
.kwc-dot-o1{transform:translate(155px,0);background:var(--purple-lt);box-shadow:0 0 8px var(--purple)}
.kwc-dot-o2{transform:translate(-100px,120px);background:var(--purple-lt);box-shadow:0 0 8px var(--purple)}
.kwc-dot-o3{transform:translate(50px,-145px);background:var(--purple-lt);box-shadow:0 0 8px var(--purple)}
.kwc-dot-m1{transform:translate(105px,0);background:var(--orange);box-shadow:0 0 8px var(--orange)}
.kwc-dot-m2{transform:translate(-60px,85px);background:var(--orange);box-shadow:0 0 8px var(--orange)}
.kwc-dot-i1{transform:translate(55px,0);background:var(--gold);box-shadow:0 0 8px var(--gold)}
.kwc-dot-i2{transform:translate(-30px,48px);background:var(--gold);box-shadow:0 0 8px var(--gold)}

/* ═══ S5 — SAFETY ═══ */
.safety{position:relative;z-index:1;padding:120px 0;background:linear-gradient(180deg,#0a0818 0%,#0c1020 50%,#0a0818 100%)}
.safety-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.safety-card{background:var(--glass);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(74,222,128,.1);border-radius:18px;padding:36px 28px;text-align:center;transition:transform .3s,box-shadow .3s,border-color .3s}
.safety-card:hover{transform:translateY(-5px) scale(1.02);box-shadow:0 0 30px rgba(74,222,128,.1);border-color:rgba(74,222,128,.25)}
.safety-icon{font-size:2rem;margin-bottom:16px}
.safety-card h3{font-size:1rem;font-weight:800;color:#fff;margin-bottom:12px;letter-spacing:.5px}
.safety-card p{font-size:.9rem;line-height:1.75;color:rgba(255,255,255,.5)}

/* ═══ S6 — PARENTS ═══ */
.parents{position:relative;z-index:1;padding:120px 0;background:linear-gradient(180deg,#0a0818 0%,#10122a 50%,#0a0818 100%)}
.parent-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start;margin-bottom:48px}
.parent-features{display:flex;flex-direction:column;gap:16px}
.pf-row{display:flex;align-items:center;gap:16px;padding:18px 20px;background:var(--glass);border-radius:12px;font-size:.95rem;color:rgba(255,255,255,.65);border:1px solid rgba(255,255,255,.04);transition:border-color .3s}
.pf-row:hover{border-color:rgba(123,47,242,.2)}
.pf-accent{width:4px;height:36px;border-radius:3px;flex-shrink:0}
.pf-a-cyan{background:var(--cyan)}
.pf-a-gold{background:var(--gold)}
.pf-a-purple{background:var(--purple)}
.pf-a-orange{background:var(--orange)}

/* Dashboard mockup */
.dash-panel{background:rgba(255,255,255,.025);border:1px solid rgba(123,47,242,.15);border-radius:18px;overflow:hidden;backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px)}
.dash-header{display:flex;align-items:center;gap:8px;padding:14px 20px;background:rgba(255,255,255,.02);border-bottom:1px solid rgba(255,255,255,.05)}
.dash-dot{width:10px;height:10px;border-radius:50%}
.dash-dot-r{background:#ff5f57}
.dash-dot-y{background:#febc2e}
.dash-dot-g{background:#28c840}
.dash-title{margin-left:8px;font-size:.75rem;font-weight:600;color:rgba(255,255,255,.35);letter-spacing:.5px;text-transform:uppercase}
.dash-body{padding:24px 20px;display:flex;flex-direction:column;gap:18px}
.dash-row{display:grid;grid-template-columns:100px 1fr 40px;align-items:center;gap:12px}
.dash-label{font-size:.72rem;color:rgba(255,255,255,.4);font-weight:600}
.dash-bar{height:6px;border-radius:3px;background:rgba(255,255,255,.06);overflow:hidden}
.dash-fill{height:100%;border-radius:3px;width:var(--w)}
.dash-fill-purple{background:linear-gradient(90deg,var(--purple),var(--purple-lt))}
.dash-fill-cyan{background:linear-gradient(90deg,var(--cyan),#38B5CC)}
