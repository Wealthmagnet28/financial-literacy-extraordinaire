/* ═══════════════════════════════════════════
   CUSTOM PROPERTIES
   ═══════════════════════════════════════════ */
:root{
	--bg:#0A0A12;--bg-mid:#0D1B3E;
	--purple:#7B2FF2;--purple-lt:#9B59F0;
	--cyan:#4FD1E8;--gold:#FFD23F;--orange:#FF6B35;
	--green:#4ADE80;
	--white:#FFFFFF;--text:#D8D8E8;--gray:#A0A0B8;
	--glass:rgba(255,255,255,.03);
	--font:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;
}

/* ═══ RESET ═══ */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:var(--font);color:var(--text);background:var(--bg);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{text-decoration:none;color:inherit}
ul{list-style:none}
.container{max-width:1180px;margin:0 auto;padding:0 24px}

/* ═══ KEYFRAMES ═══ */
@keyframes twinkle-a{0%{opacity:.3}100%{opacity:.9}}
@keyframes twinkle-b{0%{opacity:.85}100%{opacity:.3}}
@keyframes twinkle-c{0%{opacity:.35}50%{opacity:1}100%{opacity:.35}}
@keyframes grid-crawl{0%{background-position:0 0}100%{background-position:60px 60px}}
@keyframes drift-l{0%{transform:translateX(5vw)}100%{transform:translateX(-5vw)}}
@keyframes drift-r{0%{transform:translateX(-5vw)}100%{transform:translateX(5vw)}}
@keyframes spin-cw{to{transform:rotate(360deg)}}
@keyframes spin-ccw{to{transform:rotate(-360deg)}}
@keyframes core-pulse{0%,100%{transform:translate(-50%,-50%) scale(1);opacity:.9}50%{transform:translate(-50%,-50%) scale(1.05);opacity:1}}
@keyframes radial-drift{0%{transform:translate(0,0) scale(1);opacity:.7}100%{transform:var(--rd-end) scale(.2);opacity:0}}
@keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}
@keyframes rise{0%{opacity:0;transform:translateY(40px)}100%{opacity:1;transform:translateY(0)}}
@keyframes shoot-lr{0%{transform:translateX(-120px) translateY(0) rotate(215deg);opacity:0}10%{opacity:1}90%{opacity:1}100%{transform:translateX(calc(100vw + 120px)) translateY(180px) rotate(215deg);opacity:0}}
@keyframes shoot-rl{0%{transform:translateX(calc(100vw + 120px)) translateY(0) rotate(35deg);opacity:0}10%{opacity:1}90%{opacity:1}100%{transform:translateX(-120px) translateY(180px) rotate(35deg);opacity:0}}
@keyframes empire-grad{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
@keyframes kwc-orbit{to{transform:rotate(360deg)}}

/* ═══ FADE-UP ═══ */
.fade-up{opacity:0;transform:translateY(36px);transition:opacity .7s cubic-bezier(.22,1,.36,1) var(--d,.05s),transform .7s cubic-bezier(.22,1,.36,1) var(--d,.05s)}
.fade-up.in-view{opacity:1;transform:translateY(0)}

/* ═══ GRID BG ═══ */
.grid-bg{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(123,47,242,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(123,47,242,.03) 1px,transparent 1px);background-size:60px 60px;animation:grid-crawl 22s linear infinite}

