			</div>
		</footer>

		<script>
			const io = new IntersectionObserver((entries) => {
				entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in-view'); });
			}, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });
			document.querySelectorAll('.fade-up').forEach(el => io.observe(el));

			document.getElementById('burger')?.addEventListener('click', () => {
				document.getElementById('navLinks')?.classList.toggle('open');
			});
		</script>

	</body>
</html>

<style>
	/* ═══════════════════════════════════════════════
	   CUSTOM PROPERTIES
	   ═══════════════════════════════════════════════ */
	:root {
		--bg:         #0A0A12;
		--bg-mid:     #0D1B3E;
		--purple:     #7B2FF2;
		--purple-lt:  #9B59F0;
		--cyan:       #4FD1E8;
		--gold:       #FFD23F;
		--orange:     #FF6B35;
		--white:      #FFFFFF;
		--gray:       #A0A0B8;
		--text:       #D8D8E8;
		--glass:      rgba(255,255,255,0.03);
		--font: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
	}

	/* ═══════════════════════════════════════════════
	   RESET
	   ═══════════════════════════════════════════════ */
	*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
	html{scroll-behavior:smooth}
	body{font-family:var(--font);color:var(--text);background:var(--bg);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
	a{text-decoration:none;color:inherit}
	.container{max-width:1160px;margin:0 auto;padding:0 24px}

	/* ═══════════════════════════════════════════════
	   KEYFRAMES
	   ═══════════════════════════════════════════════ */
	@keyframes twinkle-a{0%{opacity:.35}100%{opacity:.9}}
	@keyframes twinkle-b{0%{opacity:.85}100%{opacity:.35}}
	@keyframes twinkle-c{0%{opacity:.4}50%{opacity:1}100%{opacity:.4}}
	@keyframes grid-crawl{0%{background-position:0 0}100%{background-position:60px 60px}}

	@keyframes drift-l{0%{transform:translateX(4vw)}100%{transform:translateX(-4vw)}}
	@keyframes drift-r{0%{transform:translateX(-4vw)}100%{transform:translateX(4vw)}}

	@keyframes spin-cw{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}
	@keyframes spin-ccw{0%{transform:rotate(0deg)}100%{transform:rotate(-360deg)}}

	@keyframes core-pulse{
		0%,100%{transform:scale(1);opacity:.92}
		50%{transform:scale(1.05);opacity:1}
	}

	@keyframes radial-drift{
		0%{transform:translate(0,0) scale(1);opacity:.7}
		100%{transform:var(--rd-end) scale(.3);opacity:0}
	}

	@keyframes shimmer-bar{
		0%{background-position:-200% 0}
		100%{background-position:200% 0}
	}

	@keyframes glow-text-pulse{
		0%,100%{filter:drop-shadow(0 0 8px var(--glow-c))}
		50%{filter:drop-shadow(0 0 16px var(--glow-c))}
	}

	@keyframes rise{
		0%{opacity:0;transform:translateY(40px)}
		100%{opacity:1;transform:translateY(0)}
	}

	/* ═══════════════════════════════════════════════
	   SCROLL FADE-UP
	   ═══════════════════════════════════════════════ */
	.fade-up{
		opacity:0;transform:translateY(36px);
		transition:opacity .7s cubic-bezier(.22,1,.36,1) var(--d,.05s),
		           transform .7s cubic-bezier(.22,1,.36,1) var(--d,.05s);
	}
	.fade-up.in-view{opacity:1;transform:translateY(0)}

	/* ═══════════════════════════════════════════════
	   GRID BG
	   ═══════════════════════════════════════════════ */
	.grid-bg{
		position:fixed;inset:0;z-index:0;pointer-events:none;
		background-image:
			linear-gradient(rgba(123,47,242,.03) 1px, transparent 1px),
			linear-gradient(90deg, rgba(123,47,242,.03) 1px, transparent 1px);
		background-size:60px 60px;
		animation:grid-crawl 22s linear infinite;
	}

	/* ═══════════════════════════════════════════════
	   STARFIELD (sparser than homepage)
	   ═══════════════════════════════════════════════ */
	.stars{position:fixed;inset:0;pointer-events:none;z-index:0}
	.stars-sm{
		animation:twinkle-a 3s ease-in-out infinite alternate;
		box-shadow:
			42px 38px 0 .5px rgba(255,255,255,.7),
			310px 24px 0 .5px rgba(255,255,255,.6),
			520px 62px 0 .5px rgba(255,255,255,.8),
			680px 88px 0 .5px rgba(255,255,255,.55),
			920px 42px 0 .5px rgba(255,255,255,.65),
			1180px 55px 0 .5px rgba(255,255,255,.75),
			85px 320px 0 .5px rgba(255,255,255,.6),
			375px 350px 0 .5px rgba(255,255,255,.7),
			620px 365px 0 .5px rgba(255,255,255,.55),
			880px 340px 0 .5px rgba(255,255,255,.65),
			1140px 375px 0 .5px rgba(255,255,255,.6),
			55px 455px 0 .5px rgba(255,255,255,.75),
			340px 480px 0 .5px rgba(255,255,255,.65),
			615px 505px 0 .5px rgba(255,255,255,.55),
			870px 490px 0 .5px rgba(255,255,255,.7),
			1135px 510px 0 .5px rgba(255,255,255,.6),
			72px 580px 0 .5px rgba(255,255,255,.65),
			350px 610px 0 .5px rgba(255,255,255,.6),
			630px 625px 0 .5px rgba(255,255,255,.7),
			905px 640px 0 .5px rgba(255,255,255,.55),
			1170px 620px 0 .5px rgba(255,255,255,.65),
			48px 710px 0 .5px rgba(255,255,255,.7),
			325px 740px 0 .5px rgba(255,255,255,.6),
			600px 750px 0 .5px rgba(255,255,255,.65),
			875px 760px 0 .5px rgba(255,255,255,.55),
			1150px 745px 0 .5px rgba(255,255,255,.7),
			130px 155px 0 .5px rgba(255,210,63,.5),
			820px 530px 0 .5px rgba(255,210,63,.45),
			260px 190px 0 .5px rgba(155,89,240,.4),
			710px 140px 0 .5px rgba(155,89,240,.45),
			190px 260px 0 .5px rgba(79,209,232,.35),
			1050px 170px 0 .5px rgba(79,209,232,.4);
	}
	.stars-md{
		animation:twinkle-b 5s ease-in-out infinite alternate;
		box-shadow:
			95px 65px 0 .75px rgba(255,255,255,.75),
			440px 48px 0 .75px rgba(255,255,255,.8),
			810px 80px 0 .75px rgba(255,255,255,.65),
			1130px 90px 0 .75px rgba(255,255,255,.7),
			60px 265px 0 .75px rgba(255,255,255,.65),
			380px 250px 0 .75px rgba(255,255,255,.7),
			690px 270px 0 .75px rgba(255,255,255,.75),
			1020px 260px 0 .75px rgba(255,255,255,.65),
			75px 430px 0 .75px rgba(255,255,255,.7),
			405px 395px 0 .75px rgba(255,255,255,.65),
			720px 410px 0 .75px rgba(255,255,255,.75),
			1045px 420px 0 .75px rgba(255,255,255,.7),
			200px 580px 0 .75px rgba(255,255,255,.75),
			515px 590px 0 .75px rgba(255,255,255,.65),
			835px 610px 0 .75px rgba(255,255,255,.7),
			250px 720px 0 .75px rgba(255,255,255,.75),
			750px 680px 0 .75px rgba(255,255,255,.7),
			1070px 695px 0 .75px rgba(255,255,255,.65),
			155px 150px 0 .75px rgba(255,210,63,.5),
			960px 140px 0 .75px rgba(255,210,63,.45),
			480px 200px 0 .75px rgba(155,89,240,.4),
			860px 490px 0 .75px rgba(79,209,232,.35);
	}
	.stars-lg{
		animation:twinkle-c 7s ease-in-out infinite alternate;
		box-shadow:
			120px 95px 0 1.25px rgba(255,255,255,.8),
			590px 140px 0 1.25px rgba(255,255,255,.75),
			1060px 75px 0 1.25px rgba(255,255,255,.8),
			165px 290px 0 1.25px rgba(255,255,255,.75),
			650px 280px 0 1.25px rgba(255,255,255,.8),
			1120px 290px 0 1.25px rgba(255,255,255,.75),
			330px 490px 0 1.25px rgba(255,255,255,.8),
			780px 500px 0 1.25px rgba(255,255,255,.7),
			90px 440px 0 1.25px rgba(255,255,255,.75),
			390px 640px 0 1.25px rgba(255,255,255,.8),
			860px 650px 0 1.25px rgba(255,255,255,.7),
			210px 730px 0 1.25px rgba(255,255,255,.8),
			730px 760px 0 1.25px rgba(255,255,255,.75),
			510px 170px 0 1.25px rgba(255,210,63,.55),
			940px 440px 0 1.25px rgba(255,210,63,.5),
			700px 350px 0 1.25px rgba(155,89,240,.45),
			260px 560px 0 1.25px rgba(79,209,232,.4);
	}

	/* ═══════════════════════════════════════════════
	   NAV
	   ═══════════════════════════════════════════════ */
	.nav{
		position:fixed;top:0;left:0;right:0;z-index:200;
		background:rgba(10,10,18,.65);
		backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);
		border-bottom:1px solid rgba(123,47,242,.1);
	}
	.nav-inner{
		max-width:1160px;margin:0 auto;padding:0 24px;
		display:flex;align-items:center;justify-content:space-between;height:72px;
	}
	.logo{display:flex;align-items:center;gap:10px;font-weight:800;font-size:1.2rem;z-index:201}
	.logo-icon{
		display:inline-flex;align-items:center;justify-content:center;
		width:38px;height:38px;
		background:linear-gradient(135deg,var(--purple),var(--orange));
		border-radius:11px;font-weight:900;font-size:1.1rem;color:#fff;
	}
	.logo-word{color:#fff;letter-spacing:-.3px}

	.nav-links{display:flex;align-items:center;gap:32px;font-size:.925rem;font-weight:500}
	.nav-links a{color:rgba(255,255,255,.6);transition:color .25s}
	.nav-links a:hover,.nav-links a.active{color:#fff}
	.nav-btn{
		background:linear-gradient(135deg,var(--purple),var(--orange));
		color:#fff!important;padding:10px 24px;border-radius:10px;font-weight:700;
		transition:transform .3s,box-shadow .3s;
		box-shadow:0 0 18px rgba(123,47,242,.3);
	}
	.nav-btn:hover{transform:translateY(-2px) scale(1.05);box-shadow:0 0 30px rgba(123,47,242,.5)}

	.burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px;z-index:201}
	.burger span{display:block;width:24px;height:2px;background:#fff;border-radius:2px}

	/* ═══════════════════════════════════════════════
	   DRIFTING BACKGROUND WORDS
	   ═══════════════════════════════════════════════ */
	.drift{
		position:absolute;
		font-size:clamp(4rem,12vw,10rem);
		font-weight:900;text-transform:uppercase;
		color:rgba(255,255,255,.025);
		letter-spacing:8px;white-space:nowrap;
		pointer-events:none;user-select:none;z-index:0;
	}
	.drift-1{top:8%;left:2%;animation:drift-l 70s ease-in-out infinite alternate}
	.drift-2{top:25%;right:-5%;animation:drift-r 80s ease-in-out infinite alternate}
	.drift-3{top:42%;left:-3%;animation:drift-l 65s ease-in-out infinite alternate}
	.drift-4{top:58%;right:0;animation:drift-r 90s ease-in-out infinite alternate}
	.drift-5{top:72%;left:5%;animation:drift-l 75s ease-in-out infinite alternate}
	.drift-6{top:88%;right:3%;animation:drift-r 85s ease-in-out infinite alternate}

	/* ═══════════════════════════════════════════════
	   GLOWING TEXT SPANS
	   ═══════════════════════════════════════════════ */
	.glow-gold,.glow-cyan,.glow-purple{
		-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;
		font-weight:600;
	}
	.glow-gold{
		background-image:linear-gradient(135deg,#FFD23F,#F5C842);
		--glow-c:rgba(255,210,63,.35);
		filter:drop-shadow(0 0 12px rgba(255,210,63,.3));
	}
	.glow-cyan{
		background-image:linear-gradient(135deg,#4FD1E8,#38B5CC);
		--glow-c:rgba(79,209,232,.35);
		filter:drop-shadow(0 0 12px rgba(79,209,232,.3));
	}
	.glow-purple{
		background-image:linear-gradient(135deg,#7B2FF2,#9B59F0);
		--glow-c:rgba(123,47,242,.35);
		filter:drop-shadow(0 0 12px rgba(123,47,242,.3));
	}

	/* ═══════════════════════════════════════════════
	   ABOUT HERO
	   ═══════════════════════════════════════════════ */
	.about-hero{
		position:relative;z-index:1;
		min-height:100vh;min-height:100svh;
		display:flex;align-items:center;
		overflow:hidden;
		padding:120px 0 80px;
		background:linear-gradient(170deg,var(--bg) 0%,#0c0a1e 30%,#0f1230 55%,#0a0818 100%);
	}

	.hero-grid{
		display:grid;
		grid-template-columns:1fr 1fr;
		gap:80px;
		align-items:center;
	}

	/* Copy side */
	.hero-copy{position:relative;z-index:2}

	.eyebrow{
		font-size:.75rem;font-weight:700;text-transform:uppercase;
		letter-spacing:3px;color:var(--cyan);margin-bottom:20px;
		opacity:0;animation:rise .8s cubic-bezier(.22,1,.36,1) .1s forwards;
	}

	.hero-copy h1{
		font-size:clamp(2.2rem,5vw,3.4rem);
		font-weight:900;color:#fff;letter-spacing:-1px;
		margin-bottom:36px;line-height:1.1;
		opacity:0;animation:rise .8s cubic-bezier(.22,1,.36,1) .2s forwards;
	}

	.body-text{
		font-size:1.05rem;line-height:1.85;
		color:rgba(255,255,255,.6);
		margin-bottom:20px;
		opacity:0;animation:rise .8s cubic-bezier(.22,1,.36,1) .35s forwards;
	}
	.body-text:nth-of-type(3){animation-delay:.45s}
	.body-text:nth-of-type(4){animation-delay:.55s}

	.mission-line{
		font-size:clamp(1.3rem,3vw,1.8rem);
		font-weight:800;color:#fff;
		margin-top:36px;
		letter-spacing:-.5px;
		opacity:0;animation:rise .8s cubic-bezier(.22,1,.36,1) .65s forwards;
		text-shadow:0 0 40px rgba(79,209,232,.15);
	}

	/* ═══════════════════════════════════════════════
	   GALAXY ORB SYSTEM
	   ═══════════════════════════════════════════════ */
	.hero-orb-wrap{
		display:flex;align-items:center;justify-content:center;
		position:relative;z-index:2;
	}

	.galaxy-system{
		position:relative;
		width:520px;height:520px;
	}

	/* Core */
	.galaxy-core{
		position:absolute;
		top:50%;left:50%;
		width:240px;height:240px;
		transform:translate(-50%,-50%);
		border-radius:50%;
		background:radial-gradient(circle,
			rgba(255,210,63,.12) 0%,
			rgba(123,47,242,.25) 30%,
			rgba(13,27,62,.6) 60%,
			rgba(10,10,18,.9) 100%
		);
		box-shadow:
			0 0 60px rgba(123,47,242,.2),
			0 0 120px rgba(79,209,232,.08),
