	/* --- Bright focal stars with radial glow --- */
	.bright-star{
		position:absolute;pointer-events:none;z-index:0;
		border-radius:50%;
	}
	.bright-star::before{
		content:'';display:block;border-radius:50%;
		background:radial-gradient(circle, rgba(255,255,255,.9) 0%, rgba(255,255,255,.3) 30%, transparent 70%);
	}
	.bs-1{top:12%;left:18%}.bs-1::before{width:6px;height:6px;box-shadow:0 0 8px 3px rgba(255,255,255,.25),0 0 20px 6px rgba(255,210,63,.12)}
	.bs-2{top:28%;right:22%}.bs-2::before{width:7px;height:7px;box-shadow:0 0 10px 4px rgba(255,255,255,.3),0 0 24px 8px rgba(155,89,240,.12)}
	.bs-3{top:55%;left:8%}.bs-3::before{width:5px;height:5px;box-shadow:0 0 8px 3px rgba(255,255,255,.25),0 0 18px 5px rgba(255,210,63,.1)}
	.bs-4{top:42%;right:12%}.bs-4::before{width:8px;height:8px;box-shadow:0 0 12px 5px rgba(255,255,255,.3),0 0 28px 8px rgba(155,89,240,.1)}
	.bs-5{top:72%;left:35%}.bs-5::before{width:6px;height:6px;box-shadow:0 0 8px 3px rgba(255,255,255,.2),0 0 20px 6px rgba(255,210,63,.12)}
	.bs-6{top:18%;left:62%}.bs-6::before{width:7px;height:7px;box-shadow:0 0 10px 4px rgba(255,255,255,.25),0 0 22px 7px rgba(155,89,240,.1)}

	/* --- Layer 2: Nebula clouds --- */
	.nebula{position:absolute;border-radius:50%;pointer-events:none}

	.neb-1{
		width:600px;height:600px;z-index:1;
		top:-10%;right:-5%;
		background:radial-gradient(circle, rgba(123,47,242,.12) 0%, rgba(123,47,242,.04) 40%, transparent 70%);
		filter:blur(80px);
		animation:neb-orbit-1 45s linear infinite;
	}
	.neb-2{
		width:500px;height:500px;z-index:1;
		bottom:-5%;left:-8%;
		background:radial-gradient(circle, rgba(255,107,53,.08) 0%, rgba(255,210,63,.05) 35%, transparent 70%);
		filter:blur(100px);
		animation:neb-drift-2 60s ease-in-out infinite alternate;
	}
	.neb-3{
		width:700px;height:700px;z-index:1;
		top:20%;left:25%;
		background:radial-gradient(circle, rgba(74,14,143,.06) 0%, transparent 65%);
		filter:blur(120px);
		animation:neb-breathe 40s ease-in-out infinite;
	}

	/* --- Page-wide shooting stars (8 total, bidirectional) --- */
	.page-shoot{
		position:fixed;pointer-events:none;z-index:1;
		width:0;height:1px;
		opacity:0;
	}
	/* Left-to-right (upper-left to lower-right) */
	.ps-1,.ps-2,.ps-3,.ps-4{
		background:linear-gradient(90deg, rgba(255,255,255,.85), rgba(255,210,63,.3), transparent);
		transform:rotate(-35deg);
	}
	/* Right-to-left (upper-right to lower-left) */
	.ps-5,.ps-6,.ps-7,.ps-8{
		background:linear-gradient(270deg, rgba(255,255,255,.85), rgba(255,210,63,.3), transparent);
		transform:rotate(35deg);
	}

	.ps-1{top:12%;left:10%;animation:shoot-lr 0.8s linear 4s infinite}
	.ps-2{top:35%;left:45%;animation:shoot-lr 0.8s linear 10s infinite}
	.ps-3{top:58%;left:20%;animation:shoot-lr 0.8s linear 16s infinite}
	.ps-4{top:82%;left:60%;animation:shoot-lr 0.8s linear 22s infinite}
	.ps-5{top:20%;right:15%;animation:shoot-rl 0.8s linear 7s infinite}
	.ps-6{top:45%;right:40%;animation:shoot-rl 0.8s linear 13s infinite}
	.ps-7{top:68%;right:10%;animation:shoot-rl 0.8s linear 19s infinite}
	.ps-8{top:90%;right:55%;animation:shoot-rl 0.8s linear 25s infinite}

	/* --- Layer 4: Cosmic dust grain --- */
	.cosmic-dust{
		position:absolute;inset:0;pointer-events:none;z-index:2;
		background-image:
			radial-gradient(circle, rgba(255,255,255,.12) 1px, transparent 1px),
			radial-gradient(circle, rgba(255,255,255,.08) 1px, transparent 1px);
		background-size:43px 43px, 97px 97px;
		background-position:0 0, 23px 23px;
		opacity:0.04;
	}

	/* Stars are now page-wide fixed elements — no per-section continuations needed */

	/* ═══════════════════════════════════════════════
	   KEYFRAMES
	   ═══════════════════════════════════════════════ */

	/* Galaxy keyframes */
	@keyframes twinkle-slow{
		0%{opacity:.4}
		100%{opacity:1}
	}
	@keyframes twinkle-med{
		0%{opacity:1}
		100%{opacity:.4}
	}
	@keyframes twinkle-fast{
		0%{opacity:.5}
		50%{opacity:1}
		100%{opacity:.4}
	}
	@keyframes neb-orbit-1{
		0%{transform:translate(0,0) rotate(0deg)}
		25%{transform:translate(40px,-30px) rotate(90deg)}
		50%{transform:translate(0,-15px) rotate(180deg)}
		75%{transform:translate(-40px,-30px) rotate(270deg)}
		100%{transform:translate(0,0) rotate(360deg)}
	}
	@keyframes neb-drift-2{
		0%{transform:translate(0,0)}
		100%{transform:translate(80px,-60px)}
	}
	@keyframes neb-breathe{
		0%,100%{transform:scale(0.9)}
		50%{transform:scale(1.1)}
	}
	@keyframes shoot-lr{
		0%{width:0;opacity:0;transform:rotate(-35deg) translateX(0)}
		10%{opacity:1;width:130px}
		50%{opacity:.5;width:150px}
		100%{opacity:0;width:0;transform:rotate(-35deg) translateX(320px)}
	}
	@keyframes shoot-rl{
		0%{width:0;opacity:0;transform:rotate(35deg) translateX(0)}
		10%{opacity:1;width:130px}
		50%{opacity:.5;width:150px}
		100%{opacity:0;width:0;transform:rotate(35deg) translateX(-320px)}
	}

	/* Existing keyframes */
	@keyframes orb-float-1{
		0%,100%{transform:translate(0,0) scale(1)}
		25%{transform:translate(60px,-40px) scale(1.08)}
		50%{transform:translate(-20px,50px) scale(0.95)}
		75%{transform:translate(40px,20px) scale(1.04)}
	}
	@keyframes orb-float-2{
		0%,100%{transform:translate(0,0) scale(1)}
		30%{transform:translate(-70px,30px) scale(1.1)}
		60%{transform:translate(30px,-60px) scale(0.92)}
	}
	@keyframes orb-float-3{
		0%,100%{transform:translate(0,0)}
		50%{transform:translate(50px,40px) scale(1.06)}
	}
	@keyframes drift-left{
		0%{transform:translateX(5vw)}
		100%{transform:translateX(-5vw)}
	}
	@keyframes drift-right{
		0%{transform:translateX(-5vw)}
		100%{transform:translateX(5vw)}
	}
	@keyframes flow-diag{
		0%{transform:translateY(100%) translateX(-30%);opacity:0}
		20%{opacity:0.15}
		80%{opacity:0.15}
		100%{transform:translateY(-100%) translateX(30%);opacity:0}
	}
	@keyframes shimmer-text{
		0%{background-position:-200% center}
		100%{background-position:200% center}
	}
	@keyframes pulse-soft{
		0%,100%{box-shadow:0 0 24px rgba(123,47,242,0.35),0 0 60px rgba(255,107,53,0.12)}
		50%{box-shadow:0 0 36px rgba(123,47,242,0.55),0 0 80px rgba(255,107,53,0.2)}
	}
	@keyframes gold-glow{
		0%,100%{box-shadow:0 0 12px var(--gold);opacity:.85}
		50%{box-shadow:0 0 28px var(--gold);opacity:1}
	}
	@keyframes rise{
		0%{opacity:0;transform:translateY(50px)}
		100%{opacity:1;transform:translateY(0)}
	}
	@keyframes float-particle{
		0%,100%{transform:translateY(0) translateX(0);opacity:.25}
		50%{transform:translateY(-30px) translateX(15px);opacity:.5}
	}
	@keyframes scroll-hint{
		0%,100%{transform:translateY(0);opacity:1}
		50%{transform:translateY(10px);opacity:.3}
	}

	/* ═══════════════════════════════════════════════
	   SCROLL-TRIGGERED FADE-UP
	   ═══════════════════════════════════════════════ */
	.fade-up{
		opacity:0;
		transform:translateY(44px);
		transition:opacity .7s cubic-bezier(.22,1,.36,1) var(--d,.05s),
		           transform .7s cubic-bezier(.22,1,.36,1) var(--d,.05s);
	}
	.fade-up.in-view{opacity:1;transform:translateY(0)}

	/* Hero uses its own entrance anim so it fires without observer */
	.anim-rise{
		opacity:0;
		animation:rise .9s cubic-bezier(.22,1,.36,1) forwards;
		animation-delay:var(--d,0s);
	}

	/* ═══════════════════════════════════════════════
	   DRIFTING BACKGROUND WORDS
	   ═══════════════════════════════════════════════ */
	.drift-word{
		position:absolute;
		font-size:clamp(5rem,14vw,12rem);
		font-weight:900;
		text-transform:uppercase;
		color:rgba(255,255,255,0.018);
		letter-spacing:8px;
		white-space:nowrap;
		pointer-events:none;
		user-select:none;
		z-index:0;
	}
	.dw-1{top:12%;left:5%;animation:drift-left 25s ease-in-out infinite alternate}
	.dw-2{top:40%;right:0;animation:drift-right 30s ease-in-out infinite alternate}
	.dw-3{bottom:22%;left:10%;animation:drift-left 22s ease-in-out infinite alternate}
	.dw-4{bottom:8%;right:5%;animation:drift-right 28s ease-in-out infinite alternate}
	.dw-bg-1{top:10%;right:0;font-size:clamp(4rem,11vw,9rem);animation:drift-right 26s ease-in-out infinite alternate}
	.dw-bg-2{top:8%;left:-2%;font-size:clamp(4rem,11vw,9rem);animation:drift-left 24s ease-in-out infinite alternate}
	.dw-q1{top:15%;left:0;font-size:clamp(3rem,10vw,8rem);animation:drift-left 20s ease-in-out infinite alternate}
	.dw-q2{bottom:20%;right:-2%;font-size:clamp(3rem,10vw,8rem);animation:drift-right 22s ease-in-out infinite alternate}
	.dw-q3{top:55%;left:30%;font-size:clamp(3rem,8vw,7rem);animation:drift-left 26s ease-in-out infinite alternate}

	/* ═══════════════════════════════════════════════
	   DIAGONAL FLOW LINES
	   ═══════════════════════════════════════════════ */
	.flow-line{
		position:absolute;
		width:2px;
		height:200px;
		background:linear-gradient(180deg,transparent,var(--purple),transparent);
		opacity:0;
		pointer-events:none;
		transform:rotate(25deg);
	}
	.fl-1{left:20%;top:0;animation:flow-diag 8s linear infinite}
	.fl-2{left:55%;top:0;animation:flow-diag 10s linear 3s infinite;height:160px;background:linear-gradient(180deg,transparent,var(--orange),transparent)}
	.fl-3{left:80%;top:0;animation:flow-diag 12s linear 6s infinite;height:180px;background:linear-gradient(180deg,transparent,var(--gold),transparent)}

	/* ═══════════════════════════════════════════════
	   FLOATING PARTICLES
	   ═══════════════════════════════════════════════ */
	.particle{
		position:absolute;
		width:3px;height:3px;
		border-radius:50%;
		background:var(--purple-lt);
		pointer-events:none;
		opacity:.2;
	}
	.p1{top:10%;left:12%;animation:float-particle 6s ease-in-out infinite}
	.p2{top:25%;left:78%;animation:float-particle 7s ease-in-out 1s infinite;background:var(--orange)}
	.p3{top:45%;left:35%;animation:float-particle 5s ease-in-out .5s infinite;background:var(--gold)}
	.p4{top:60%;left:65%;animation:float-particle 8s ease-in-out 2s infinite}
	.p5{top:75%;left:20%;animation:float-particle 6.5s ease-in-out 1.5s infinite;background:var(--orange)}
	.p6{top:15%;left:50%;animation:float-particle 7s ease-in-out 3s infinite;background:var(--gold)}
	.p7{top:85%;left:82%;animation:float-particle 5.5s ease-in-out .8s infinite}
	.p8{top:40%;left:8%;animation:float-particle 9s ease-in-out 2.5s infinite;background:var(--orange)}

	/* ═══════════════════════════════════════════════
	   NAV
	   ═══════════════════════════════════════════════ */
	.nav{
		position:fixed;top:0;left:0;right:0;z-index:200;
		background:rgba(10,10,18,0.65);
		backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);
		border-bottom:1px solid rgba(123,47,242,0.1);
	}
	.nav-inner{
		max-width:1160px;margin:0 auto;padding:0 24px;
		display:flex;align-items:center;justify-content:space-between;
		height:72px;
	}
	.logo{display:flex;align-items:center;gap:10px;font-weight:800;font-size:1.2rem;z-index:201}
	.logo-icon{
		display:inline-flex;align-items:center;justify-content:center;
		width:38px;height:38px;
		background:linear-gradient(135deg,var(--purple),var(--orange));
		border-radius:11px;font-weight:900;font-size:1.1rem;color:#fff;
	}
	.logo-word{color:#fff;letter-spacing:-.3px}

	.nav-links{display:flex;align-items:center;gap:32px;font-size:.925rem;font-weight:500}
	.nav-links a{color:rgba(255,255,255,.6);transition:color .25s}
	.nav-links a:hover{color:#fff}
	.nav-btn{
		background:linear-gradient(135deg,var(--purple),var(--orange));
		color:#fff!important;padding:10px 24px;border-radius:10px;font-weight:700;
		transition:transform .3s,box-shadow .3s;
		box-shadow:0 0 18px rgba(123,47,242,0.3);
	}
	.nav-btn:hover{transform:translateY(-2px) scale(1.05);box-shadow:0 0 30px rgba(123,47,242,.5)}

	.burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px;z-index:201}
	.burger span{display:block;width:24px;height:2px;background:#fff;border-radius:2px}

	/* ═══════════════════════════════════════════════
	   BUTTONS (global)
	   ═══════════════════════════════════════════════ */
	.btn-grad{
		display:inline-flex;align-items:center;justify-content:center;
		padding:16px 40px;font-size:1.05rem;font-weight:700;border-radius:14px;
		background:linear-gradient(135deg,var(--purple),var(--orange));
		color:#fff;border:none;cursor:pointer;
		transition:transform .3s,box-shadow .3s;
		animation:pulse-soft 3.5s ease-in-out infinite;
	}
	.btn-grad:hover{
		transform:translateY(-3px) scale(1.05);
		box-shadow:0 0 44px rgba(255,107,53,.5),0 0 90px rgba(123,47,242,.2);
	}

	.btn-outline{
		display:inline-flex;align-items:center;justify-content:center;
		padding:16px 40px;font-size:1.05rem;font-weight:600;border-radius:14px;
		background:transparent;color:#fff;
		border:1.5px solid rgba(255,255,255,.2);
		backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
		cursor:pointer;transition:all .3s;
	}
	.btn-outline:hover{
		background:var(--purple);border-color:var(--purple);
		transform:translateY(-3px) scale(1.05);
		box-shadow:0 0 30px rgba(123,47,242,.35);
	}

	.btn-white{
		display:inline-flex;align-items:center;justify-content:center;
		padding:20px 52px;font-size:1.15rem;font-weight:700;border-radius:16px;
		background:#fff;color:var(--bg);border:none;cursor:pointer;
		transition:transform .3s,box-shadow .3s;
		box-shadow:0 0 30px rgba(123,47,242,.25);
	}
	.btn-white:hover{
		transform:translateY(-3px) scale(1.05);
		box-shadow:0 0 50px rgba(123,47,242,.45),0 0 80px rgba(255,107,53,.15);
	}

	/* ═══════════════════════════════════════════════
	   SECTION TYPOGRAPHY
	   ═══════════════════════════════════════════════ */
	.sec-eyebrow{
		text-align:center;font-size:.8rem;font-weight:700;
		text-transform:uppercase;letter-spacing:3px;color:var(--orange);margin-bottom:14px;
	}
	.sec-title{
		text-align:center;font-size:clamp(2rem,4.5vw,3.1rem);font-weight:800;
		color:#fff;margin-bottom:60px;letter-spacing:-1px;line-height:1.12;
	}

	/* ═══════════════════════════════════════════════
	   HERO
	   ═══════════════════════════════════════════════ */
	.hero{
		position:relative;min-height:100vh;min-height:100svh;
		display:flex;flex-direction:column;align-items:center;justify-content:center;
		overflow:hidden;z-index:1;
		background:linear-gradient(170deg,#0A0A12 0%,#120a28 35%,#1a0e3a 65%,#0f0820 100%);
	}

	/* Orbs */
	.orb{position:absolute;border-radius:50%;filter:blur(80px);pointer-events:none;z-index:3}
	.orb-1{width:600px;height:600px;background:radial-gradient(circle,rgba(123,47,242,.18),transparent 70%);top:-15%;right:-10%;animation:orb-float-1 16s ease-in-out infinite}
	.orb-2{width:420px;height:420px;background:radial-gradient(circle,rgba(255,107,53,.14),transparent 70%);bottom:0;left:-8%;animation:orb-float-2 13s ease-in-out infinite}
	.orb-3{width:300px;height:300px;background:radial-gradient(circle,rgba(255,210,63,.08),transparent 70%);top:35%;left:45%;animation:orb-float-3 18s ease-in-out infinite}
	.orb-4{width:200px;height:200px;background:radial-gradient(circle,rgba(123,47,242,.2),transparent 70%);bottom:20%;right:15%;animation:orb-float-2 14s ease-in-out infinite reverse}
	.orb-5{width:260px;height:260px;background:radial-gradient(circle,rgba(255,107,53,.15),transparent 70%);top:10%;left:20%;animation:orb-float-1 20s ease-in-out infinite reverse}

	.hero-content{position:relative;z-index:2;text-align:center;max-width:920px;padding:0 24px}

	.hero-h1{
		font-size:clamp(2.8rem,8vw,6rem);
		font-weight:900;line-height:1;letter-spacing:-3px;
		color:#fff;margin-bottom:0;
		text-shadow:0 0 60px rgba(123,47,242,.15);
	}
	.hero-h1-offset{padding-left:clamp(1rem,5vw,4rem)}
	.hero-h1-accent{padding-right:clamp(1rem,5vw,4rem);margin-bottom:32px}

	.glow-gold,.glow-orange,.glow-purple{
		-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;
	}
	.glow-gold{
		background-image:linear-gradient(135deg,#FFD23F,#F5C842);
		filter:drop-shadow(0 0 18px rgba(255,210,63,.3)) drop-shadow(0 0 40px rgba(255,210,63,.1));
	}
	.glow-orange{
		background-image:linear-gradient(135deg,#FF6B35,#E8734A);
		filter:drop-shadow(0 0 18px rgba(255,107,53,.3)) drop-shadow(0 0 40px rgba(255,107,53,.1));
	}
	.glow-purple{
		background-image:linear-gradient(135deg,#7B2FF2,#9B59F0);
		filter:drop-shadow(0 0 18px rgba(123,47,242,.3)) drop-shadow(0 0 40px rgba(123,47,242,.1));
	}

	.hero-sub{
		font-size:clamp(1rem,2vw,1.25rem);color:var(--gray);
		max-width:580px;margin:0 auto 44px;line-height:1.7;
	}
	.hero-btns{display:flex;gap:18px;justify-content:center;flex-wrap:wrap}

	/* Stats bar */
	.stats-bar{
		position:absolute;bottom:0;left:0;right:0;z-index:3;
		display:flex;align-items:center;justify-content:center;gap:0;
		background:rgba(10,10,18,.6);
		backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
		border-top:1px solid rgba(123,47,242,.1);
		padding:18px 24px;flex-wrap:wrap;
	}
	.stat-item{display:flex;flex-direction:column;align-items:center;padding:0 clamp(16px,3vw,40px)}
	.stat-val{font-size:1.15rem;font-weight:800;color:#fff}
	.stat-lbl{font-size:.7rem;color:var(--gray);text-transform:uppercase;letter-spacing:1.5px;margin-top:2px}
	.stat-sep{width:1px;height:32px;background:rgba(255,255,255,.08)}

	/* ═══════════════════════════════════════════════
	   WHY CLUB FLE
	   ═══════════════════════════════════════════════ */
	.why{
		position:relative;z-index:1;
		padding:120px 0;overflow:hidden;
		background:linear-gradient(180deg,var(--bg) 0%,var(--bg-alt) 100%);
	}
	.why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}

	.glass-card{
		background:var(--glass);
		backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
		border:1px solid rgba(123,47,242,.12);
		border-radius:var(--radius-lg);
		padding:40px 32px;
		transition:transform .35s cubic-bezier(.22,1,.36,1),box-shadow .35s,border-color .35s,background .35s;
	}
	.glass-card:hover{
		transform:translateY(-8px);
		background:rgba(255,255,255,.06);
		border-color:rgba(123,47,242,.35);
		box-shadow:0 20px 60px rgba(123,47,242,.15),0 0 40px rgba(255,107,53,.08);
	}
	.gc-emoji{display:block;font-size:2.6rem;margin-bottom:20px}
	.glass-card h3{font-size:1.25rem;font-weight:700;color:#fff;margin-bottom:12px}
	.glass-card p{font-size:.93rem;color:rgba(255,255,255,.55);line-height:1.7}

	/* ═══════════════════════════════════════════════
	   BRANCHES
	   ═══════════════════════════════════════════════ */
	.branches{
		position:relative;z-index:1;padding:120px 0;overflow:hidden;
		background:linear-gradient(180deg,var(--bg-alt) 0%,#1a0c38 30%,#2a1050 60%,#1f0a30 100%);
	}
	.branch-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}

	.branch-card{
		background:var(--glass);
		backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
		border:1px solid rgba(255,255,255,.06);
		border-radius:var(--radius-lg);
		padding:36px 28px 32px;
		border-top:3px solid transparent;
		transition:transform .35s cubic-bezier(.22,1,.36,1),box-shadow .35s,border-color .35s;
	}
	.bc-purple{border-top-color:var(--purple)}
	.bc-orange{border-top-color:var(--orange)}
	.bc-gold{border-top-color:var(--gold)}
	.bc-coral{border-top-color:var(--coral)}

	.branch-card:hover{
		transform:translateY(-8px);
		box-shadow:0 20px 60px rgba(123,47,242,.12);
		border-color:rgba(255,255,255,.12);
	}
	.bc-purple:hover{box-shadow:0 20px 60px rgba(123,47,242,.2),0 0 30px rgba(123,47,242,.1)}
	.bc-orange:hover{box-shadow:0 20px 60px rgba(255,107,53,.2),0 0 30px rgba(255,107,53,.1)}
	.bc-gold:hover{box-shadow:0 20px 60px rgba(255,210,63,.15),0 0 30px rgba(255,210,63,.08)}
	.bc-coral:hover{box-shadow:0 20px 60px rgba(232,115,74,.18),0 0 30px rgba(232,115,74,.1)}

	.bc-emoji{display:block;font-size:2.4rem;margin-bottom:18px}
	.branch-card h3{font-size:1.2rem;font-weight:700;color:#fff;margin-bottom:10px}
	.branch-card p{font-size:.9rem;color:rgba(255,255,255,.5);line-height:1.65}

	/* ═══════════════════════════════════════════════
	   FEATURES
	   ═══════════════════════════════════════════════ */
	.features{
		position:relative;z-index:1;padding:120px 0;overflow:hidden;
		background:linear-gradient(180deg,#1f0a30 0%,var(--bg-alt) 40%,var(--bg) 100%);
	}
	.feat-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}

	.feat-block{
		display:flex;gap:20px;align-items:flex-start;
		padding:32px 28px;
		background:var(--glass);
		border-radius:var(--radius);
		border-left:3px solid transparent;
		transition:transform .3s,box-shadow .3s,border-color .3s,background .3s;
	}
	.fb-purple{border-left-color:var(--purple)}
	.fb-orange{border-left-color:var(--orange)}
	.fb-gold{border-left-color:var(--gold)}

	.feat-block:hover{
		transform:translateY(-4px);
		background:rgba(255,255,255,.06);
	}
	.fb-purple:hover{box-shadow:0 0 30px rgba(123,47,242,.15);border-left-color:var(--purple-lt)}
	.fb-orange:hover{box-shadow:0 0 30px rgba(255,107,53,.15);border-left-color:#ff8555}
	.fb-gold:hover{box-shadow:0 0 30px rgba(255,210,63,.12);border-left-color:#ffe066}

	.fb-icon{
		flex-shrink:0;width:52px;height:52px;
		display:flex;align-items:center;justify-content:center;
		background:linear-gradient(135deg,rgba(123,47,242,.15),rgba(255,107,53,.1));
		border-radius:14px;font-size:1.5rem;
	}
	.feat-block h3{font-size:1.1rem;font-weight:700;color:#fff;margin-bottom:6px}
	.feat-block p{font-size:.9rem;color:rgba(255,255,255,.5);line-height:1.6}

	/* ═══════════════════════════════════════════════
	   QUOTE STRIP
	   ═══════════════════════════════════════════════ */
	.quote-strip{
		position:relative;z-index:1;padding:130px 0;overflow:hidden;
		background:linear-gradient(180deg,var(--bg) 0%,#130a28 50%,var(--bg) 100%);
	}
	.quote-inner{text-align:center;max-width:760px;margin:0 auto;position:relative}
	.quote-inner blockquote{
		font-size:clamp(1.4rem,3.5vw,2.2rem);font-weight:700;font-style:italic;
		color:#fff;line-height:1.45;margin-bottom:36px;border:none;padding:0;
	}
	.gold-line{
		width:80px;height:4px;margin:0 auto 20px;border-radius:2px;
		background:linear-gradient(90deg,var(--gold),var(--orange));
		animation:gold-glow 3s ease-in-out infinite;
	}
	.quote-attr{
		font-size:.85rem;text-transform:uppercase;letter-spacing:3px;
		color:rgba(255,210,63,.45);font-weight:700;
	}

	/* ═══════════════════════════════════════════════
	   FAQ
	   ═══════════════════════════════════════════════ */
	.faq{
		position:relative;z-index:1;padding:120px 0;
		background:linear-gradient(180deg,var(--bg) 0%,var(--bg-alt) 100%);
	}
	.faq-list{max-width:740px;margin:0 auto;display:flex;flex-direction:column;gap:0}

	.faq-item{border-bottom:1px solid rgba(255,255,255,.06)}
	.faq-toggle{display:none}

	.faq-q{
		display:flex;align-items:center;justify-content:space-between;
		padding:22px 0 22px 16px;
		font-size:1.05rem;font-weight:600;color:#fff;
		cursor:pointer;border-left:3px solid var(--purple);
		transition:color .25s;
		user-select:none;
	}
	.faq-q:hover{color:var(--purple-lt)}

	.faq-chevron{
		display:inline-block;width:10px;height:10px;
		border-right:2px solid rgba(255,255,255,.4);
		border-bottom:2px solid rgba(255,255,255,.4);
		transform:rotate(45deg);
		transition:transform .35s;
		flex-shrink:0;margin-left:16px;
	}

	.faq-a{
		max-height:0;overflow:hidden;
		transition:max-height .45s cubic-bezier(.22,1,.36,1),padding .45s;
		padding:0 0 0 19px;
	}
	.faq-a p{font-size:.93rem;color:rgba(255,255,255,.5);line-height:1.7;padding-bottom:20px}

	.faq-toggle:checked ~ .faq-q .faq-chevron{transform:rotate(-135deg)}
	.faq-toggle:checked ~ .faq-a{max-height:220px;padding-top:4px}

	/* ═══════════════════════════════════════════════
	   FINAL CTA
	   ═══════════════════════════════════════════════ */
	.final-cta{
		position:relative;z-index:1;padding:120px 0;
		background:linear-gradient(135deg,var(--purple) 0%,var(--orange) 50%,var(--gold) 100%);
	}
	.final-cta::before{
		content:'';position:absolute;inset:0;
		background:radial-gradient(ellipse at 25% 50%,rgba(255,255,255,.12),transparent 60%);
		pointer-events:none;
	}
	.cta-inner{text-align:center;position:relative}
	.cta-inner h2{
		font-size:clamp(1.8rem,4.5vw,3rem);font-weight:900;color:#fff;
		margin-bottom:16px;line-height:1.12;letter-spacing:-1px;
		max-width:700px;margin-left:auto;margin-right:auto;
		text-shadow:0 2px 20px rgba(0,0,0,.2);
	}
	.cta-inner p{font-size:1.1rem;color:rgba(255,255,255,.8);margin-bottom:40px}

	/* ═══════════════════════════════════════════════
	   FOOTER
	   ═══════════════════════════════════════════════ */
	.footer{
		position:relative;z-index:1;padding:48px 0;
		background:var(--bg);
		border-top:1px solid rgba(123,47,242,.08);
		text-align:center;
	}
	.footer-copy{font-size:.85rem;color:rgba(255,255,255,.3);margin-bottom:16px}
	.footer-links{display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:16px}
	.footer-links a{font-size:.85rem;color:rgba(255,255,255,.4);transition:color .25s}
	.footer-links a:hover{color:var(--gold)}
	.footer-dot{width:4px;height:4px;border-radius:50%;background:rgba(255,255,255,.15)}
	.footer-tagline{font-size:.75rem;color:rgba(255,255,255,.18);letter-spacing:.5px}

	/* ═══════════════════════════════════════════════
	   RESPONSIVE
	   ═══════════════════════════════════════════════ */
	@media(max-width:1024px){
		.branch-grid{grid-template-columns:1fr 1fr}
	}

	@media(max-width:768px){
		/* Galaxy: reduce stars on mobile */
		.page-stars-sm{
			box-shadow:
				42px 38px 0 0.5px rgba(255,255,255,.75),
				187px 92px 0 0.5px rgba(255,255,255,.8),
				310px 24px 0 0.5px rgba(255,255,255,.65),
				85px 320px 0 0.5px rgba(255,255,255,.65),
				230px 280px 0 0.5px rgba(255,255,255,.8),
				375px 350px 0 0.5px rgba(255,255,255,.7),
				55px 455px 0 0.5px rgba(255,255,255,.8),
				198px 420px 0 0.5px rgba(255,255,255,.65),
				340px 480px 0 0.5px rgba(255,255,255,.7),
				72px 580px 0 0.5px rgba(255,255,255,.7),
				210px 555px 0 0.5px rgba(255,255,255,.75),
				350px 610px 0 0.5px rgba(255,255,255,.65),
				48px 710px 0 0.5px rgba(255,255,255,.7),
				185px 680px 0 0.5px rgba(255,255,255,.8),
				325px 740px 0 0.5px rgba(255,255,255,.65),
				130px 155px 0 0.5px rgba(255,210,63,.55),
				260px 190px 0 0.5px rgba(155,89,240,.45);
		}
		.page-stars-md{
			box-shadow:
				95px 65px 0 0.75px rgba(255,255,255,.8),
				285px 120px 0 0.75px rgba(255,255,255,.7),
				60px 265px 0 0.75px rgba(255,255,255,.7),
				215px 310px 0 0.75px rgba(255,255,255,.85),
				380px 250px 0 0.75px rgba(255,255,255,.75),
