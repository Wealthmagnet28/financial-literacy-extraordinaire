---
// ── MOCK DATA (matches the BudgetSummary / FinancialGoal / Transaction /
//    Alert / AccountAccess / InvestmentHolding shapes from the spec) ──

const summary = {
	currentBalance: 1250.40,
	weeklyBudgetMin: 140,
	weeklyBudgetMax: 175,
	dailySafeSpend: 22,
	spentThisWeek: 200,
	remainingToGoal: 350,
	goalProgressPercent: 56,
	status: "Over budget this week — still on track for your goal",
};

const goals = [
	{
		id: "birthday",
		title: "Birthday Fund",
		goalType: "Celebration",
		targetAmount: 800,
		currentAmount: 450,
		dueDate: "in 45 days",
		remainingPaychecks: 3,
		recommendedContribution: 117,
		status: "on track",
		accent: "gold",
	},
	{
		id: "vacation",
		title: "Vacation Fund",
		goalType: "Travel",
		targetAmount: 1500,
		currentAmount: 300,
		dueDate: "in 90 days",
		remainingPaychecks: 6,
		recommendedContribution: 200,
		status: "needs attention",
		accent: "cyan",
	},
];

const aiFeed = [
	{
		tone: "encouraging",
		category: "Weekly Spending",
		message: "Your birthday is coming up on the 24th and you've spent $200 this week. Your daily budget is $20 and weekly budget is $140–$175; you went over this week. Let's aim to budget better next week — no worries, you're still on track.",
	},
	{
		tone: "motivational",
		category: "Goal Projection",
		message: "Goal: $800 for your birthday. Current: $450. Paychecks left: 3. Save $117 per paycheck and you'll hit your goal — let's do it!",
	},
	{
		tone: "supportive",
		category: "Habit Watch",
		message: "At $10/day on food and $10/day on gas, you're on pace to exceed this week's budget — consider trimming $5/day on food to stay within limits.",
	},
	{
		tone: "success",
		category: "Milestone",
		message: "GREAT JOB!! You saved more than expected for your birthday — keep going. Vacation is in 34 days; this extra saved money gives you an early buffer.",
	},
	{
		tone: "urgent",
		category: "Security",
		message: "Your accountant logged in 2 hours ago. They have access to habit analytics only. Revoke access or schedule access windows anytime.",
	},
];

const weeklySpending = [
	{ week: "4 wks ago", actual: 132, min: 140, max: 175 },
	{ week: "3 wks ago", actual: 158, min: 140, max: 175 },
	{ week: "2 wks ago", actual: 121, min: 140, max: 175 },
	{ week: "This week", actual: 200, min: 140, max: 175 },
];

const habits = [
	{ category: "Food", icon: "🍔", avgDaily: 10, trend: "up", trendLabel: "+18% vs last month", accent: "orange" },
	{ category: "Gas", icon: "⛽", avgDaily: 10, trend: "flat", trendLabel: "steady", accent: "gold" },
	{ category: "Subscriptions", icon: "📱", avgDaily: 4, trend: "down", trendLabel: "-12% vs last month", accent: "cyan" },
];

const investments = [
	{ name: "Total Market Index", symbol: "VTI", value: 4820, costBasis: 4300, gainLoss: 520, riskLevel: "Moderate" },
	{ name: "Growth Tech Fund", symbol: "QQQ", value: 2140, costBasis: 2400, gainLoss: -260, riskLevel: "High" },
	{ name: "Bond Ladder", symbol: "BND", value: 1560, costBasis: 1500, gainLoss: 60, riskLevel: "Low" },
];

const accountAccess = [
	{
		grantedTo: "You",
		userRole: "Owner",
		scope: "Full access",
		expiresAt: "Never",
		lastLoginAt: "Active now",
		active: true,
	},
	{
		grantedTo: "Jane D. — Accountant",
		userRole: "Accountant",
		scope: "Habit analytics only",
		expiresAt: "30 days",
		lastLoginAt: "2 hours ago",
		active: true,
	},
];

const alerts = [
	{ severity: "warning", type: "Overspend", message: "You went $60 over your weekly budget.", createdAt: "Today" },
	{ severity: "urgent", type: "Unusual Transfer", message: "$250 moved from your joint account without a matching shared approval.", createdAt: "9:12 AM" },
	{ severity: "success", type: "Milestone", message: "Birthday goal is ahead of projection by $40.", createdAt: "Yesterday" },
];

const severityAccent: Record<string, string> = {
	warning: "gold",
	urgent: "orange",
	success: "cyan",
};

const toneAccent: Record<string, string> = {
	encouraging: "purple",
	motivational: "gold",
	supportive: "cyan",
	success: "gold",
	urgent: "orange",
};
---

<html lang="en">
<head>
	<meta charset="utf-8" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="generator" content={Astro.generator} />
	<meta name="description" content="Club FLE Budget Tracker — AI-powered budgeting with goals, spending insights, habit monitoring, and secure account access." />
	<title>Budget Tracker — Club FLE</title>
</head>
<body>

<div class="grid-bg" aria-hidden="true"></div>
<div class="pg-stars pg-stars-sm" aria-hidden="true"></div>
<div class="pg-stars pg-stars-md" aria-hidden="true"></div>

<nav class="nav">
	<div class="nav-inner">
		<a href="/" class="logo">
			<span class="logo-icon">$</span>
			<span class="logo-word">Club FLE</span>
		</a>
		<div class="nav-links" id="navLinks">
			<a href="/">Home</a>
			<a href="/about">About</a>
			<a href="/#features">Features</a>
			<a href="/budget-tracker" class="active">Budget Tracker</a>
			<a href="/#faq">Contact</a>
		</div>
		<button class="burger" id="burger" aria-label="Menu">
			<span></span><span></span><span></span>
		</button>
	</div>
</nav>

<main class="page">
	<div class="container">

		<!-- PAGE HEADER -->
		<header class="page-head fade-up">
			<p class="eyebrow">Your Money, Understood</p>
			<h1>Budget Tracker</h1>
			<p class="page-sub">AI-powered insight into your spending, goals, habits, and investments — built to keep you moving, not just watching.</p>
			<div class="quick-actions">
				<button class="qa-btn qa-primary">+ Add Transaction</button>
				<button class="qa-btn">+ Set Goal</button>
				<button class="qa-btn">Connect Account</button>
			</div>
		</header>

		<!-- SNAPSHOT -->
		<section class="snapshot fade-up" style="--d:.05s">
			<div class="snap-card">
				<span class="snap-label">Today's Safe Spend</span>
				<span class="snap-value gl-cyan">${summary.dailySafeSpend}</span>
				<span class="snap-note">Based on this week's remaining budget</span>
			</div>
			<div class="snap-card">
				<span class="snap-label">This Week vs Budget</span>
				<span class="snap-value gl-gold">${summary.spentThisWeek}</span>
				<span class="snap-note">Target range ${summary.weeklyBudgetMin}–${summary.weeklyBudgetMax}</span>
				<div class="snap-bar">
					<div class="snap-bar-range" style={`left:${(summary.weeklyBudgetMin/250)*100}%;width:${((summary.weeklyBudgetMax-summary.weeklyBudgetMin)/250)*100}%`}></div>
					<div class="snap-bar-actual over" style={`width:${Math.min((summary.spentThisWeek/250)*100,100)}%`}></div>
				</div>
			</div>
			<div class="snap-card">
				<span class="snap-label">Goal Progress</span>
				<span class="snap-value gl-purple">{summary.goalProgressPercent}%</span>
				<span class="snap-note">${summary.remainingToGoal} remaining</span>
			</div>
			<div class="snap-card snap-status">
				<span class="snap-label">Status</span>
				<span class="snap-status-text">{summary.status}</span>
			</div>
		</section>

		<div class="two-col">
			<!-- AI FEED -->
			<section class="panel ai-feed fade-up" style="--d:.1s">
				<h2 class="panel-h">AI Feed</h2>
				<div class="feed-list">
					{aiFeed.map((item) => (
						<div class={`feed-item accent-${toneAccent[item.tone]}`}>
							<span class="feed-cat">{item.category}</span>
							<p>{item.message}</p>
						</div>
					))}
				</div>
			</section>

			<!-- ALERTS -->
			<section class="panel alerts-panel fade-up" style="--d:.15s">
				<h2 class="panel-h">Alerts</h2>
				<div class="alert-list">
					{alerts.map((a) => (
						<div class={`alert-item accent-${severityAccent[a.severity]}`}>
							<div class="alert-top">
								<span class="alert-type">{a.type}</span>
								<span class="alert-time">{a.createdAt}</span>
							</div>
							<p>{a.message}</p>
						</div>
					))}
				</div>
			</section>
		</div>

		<!-- GOALS -->
		<section class="panel-full fade-up" style="--d:.1s">
			<h2 class="panel-h">Goals</h2>
			<div class="goal-grid">
				{goals.map((g) => {
					const pct = Math.round((g.currentAmount / g.targetAmount) * 100);
					return (
						<div class={`goal-card accent-${g.accent}`}>
							<div class="goal-top">
								<h3>{g.title}</h3>
								<span class="goal-type">{g.goalType}</span>
							</div>
							<div class="goal-ring-row">
								<div class="goal-ring">
									<svg viewBox="0 0 80 80">
										<circle cx="40" cy="40" r="34" fill="none" stroke="rgba(255,255,255,.08)" stroke-width="6"/>
										<circle cx="40" cy="40" r="34" fill="none" class={`ring-stroke-${g.accent}`} stroke-width="6" stroke-dasharray={`${(pct/100)*214} 214`} stroke-linecap="round" transform="rotate(-90 40 40)"/>
									</svg>
									<span class="ring-pct">{pct}%</span>
								</div>
								<div class="goal-nums">
									<span class="goal-current">${g.currentAmount}<span class="goal-of"> / ${g.targetAmount}</span></span>
									<span class="goal-due">Due {g.dueDate}</span>
								</div>
							</div>
							<div class="goal-foot">
								<span>{g.remainingPaychecks} paychecks left</span>
								<span class="goal-rec">Save ${g.recommendedContribution}/paycheck</span>
							</div>
							<span class={`goal-status status-${g.status.replace(' ', '-')}`}>{g.status}</span>
						</div>
					);
				})}
			</div>
		</section>

		<!-- WEEKLY SPENDING -->
		<section class="panel-full fade-up" style="--d:.1s">
			<h2 class="panel-h">Weekly Spending</h2>
			<div class="week-chart">
				{weeklySpending.map((w) => {
					const isOver = w.actual > w.max;
					const barPct = Math.min((w.actual / 250) * 100, 100);
					const rangeLeft = (w.min / 250) * 100;
					const rangeWidth = ((w.max - w.min) / 250) * 100;
					return (
						<div class="week-row">
							<span class="week-label">{w.week}</span>
							<div class="week-bar-track">
								<div class="week-range" style={`left:${rangeLeft}%;width:${rangeWidth}%`}></div>
								<div class={`week-actual ${isOver ? 'over' : 'under'}`} style={`width:${barPct}%`}></div>
							</div>
							<span class={`week-amount ${isOver ? 'gl-orange' : 'gl-cyan'}`}>${w.actual}</span>
						</div>
					);
				})}
			</div>
		</section>

		<div class="two-col">
			<!-- HABITS -->
			<section class="panel fade-up" style="--d:.1s">
				<h2 class="panel-h">Habits</h2>
				<div class="habit-list">
					{habits.map((h) => (
						<div class={`habit-card accent-${h.accent}`}>
							<span class="habit-icon">{h.icon}</span>
							<div class="habit-info">
								<span class="habit-cat">{h.category}</span>
								<span class="habit-avg">${h.avgDaily}/day avg</span>
							</div>
							<span class={`habit-trend trend-${h.trend}`}>{h.trendLabel}</span>
						</div>
					))}
				</div>
			</section>

			<!-- INVESTMENTS -->
			<section class="panel fade-up" style="--d:.15s">
				<h2 class="panel-h">Investments</h2>
				<div class="invest-list">
					{investments.map((inv) => (
						<div class="invest-row">
							<div class="invest-name">
								<span class="invest-symbol">{inv.symbol}</span>
								<span class="invest-full">{inv.name}</span>
							</div>
							<span class="invest-risk">{inv.riskLevel}</span>
							<span class="invest-value">${inv.value.toLocaleString()}</span>
							<span class={`invest-gain ${inv.gainLoss >= 0 ? 'gain-pos' : 'gain-neg'}`}>
								{inv.gainLoss >= 0 ? '+' : ''}${inv.gainLoss}
							</span>
						</div>
					))}
				</div>
			</section>
		</div>

		<!-- ACCOUNT ACCESS -->
		<section class="panel-full fade-up" style="--d:.1s">
			<h2 class="panel-h">Account &amp; Accountant Access</h2>
			<p class="access-note">This view shows only habit analytics — no bank credentials shared.</p>
			<div class="access-list">
				{accountAccess.map((a) => (
					<div class="access-row">
						<div class="access-who">
							<span class={`access-dot ${a.active ? 'dot-active' : 'dot-inactive'}`}></span>
							<span class="access-name">{a.grantedTo}</span>
							<span class="access-role">{a.userRole}</span>
						</div>
						<span class="access-scope">{a.scope}</span>
						<span class="access-login">Last login: {a.lastLoginAt}</span>
						<span class="access-expires">Expires: {a.expiresAt}</span>
						{a.userRole !== 'Owner' && <button class="access-revoke">Revoke</button>}
					</div>
				))}
			</div>
		</section>

	</div>
</main>

<footer class="footer">
	<div class="container">
		<p class="footer-copy">&copy; 2026 Financial Literacy Extraordinaire. All rights reserved.</p>
		<div class="footer-links">
			<a href="/">Home</a><span class="footer-dot"></span>
			<a href="/about">About</a><span class="footer-dot"></span>
			<a href="/#features">Features</a><span class="footer-dot"></span>
			<a href="/#faq">Contact</a>
		</div>
		<p class="footer-tagline">Club FLE — Master Your Money. Build Your Future.</p>
	</div>
</footer>

<script>
	const io = new IntersectionObserver((entries) => {
		entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in-view'); });
	}, { threshold: 0.05, rootMargin: '0px 0px -40px 0px' });
	document.querySelectorAll('.fade-up').forEach(el => io.observe(el));
	document.getElementById('burger')?.addEventListener('click', () => {
		document.getElementById('navLinks')?.classList.toggle('open');
	});
</script>

</body>
</html>

<style>
:root{
	--bg:#0A0A12;--bg-mid:#0D1B3E;
	--purple:#7B2FF2;--purple-lt:#9B59F0;
	--cyan:#4FD1E8;--gold:#FFD23F;--orange:#FF6B35;
	--green:#4ADE80;--red:#FF5C5C;
	--white:#FFFFFF;--text:#D8D8E8;--gray:#A0A0B8;
	--glass:rgba(255,255,255,.03);
	--font:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;
}

*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:var(--font);color:var(--text);background:var(--bg);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{text-decoration:none;color:inherit}
.container{max-width:1180px;margin:0 auto;padding:0 24px}

@keyframes twinkle-a{0%{opacity:.3}100%{opacity:.85}}
@keyframes twinkle-b{0%{opacity:.8}100%{opacity:.3}}
@keyframes grid-crawl{0%{background-position:0 0}100%{background-position:60px 60px}}
@keyframes rise{0%{opacity:0;transform:translateY(30px)}100%{opacity:1;transform:translateY(0)}}

.fade-up{opacity:0;transform:translateY(28px);transition:opacity .6s cubic-bezier(.22,1,.36,1) var(--d,.05s),transform .6s cubic-bezier(.22,1,.36,1) var(--d,.05s)}
.fade-up.in-view{opacity:1;transform:translateY(0)}

.grid-bg{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(123,47,242,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(123,47,242,.03) 1px,transparent 1px);background-size:60px 60px;animation:grid-crawl 22s linear infinite}

.pg-stars{position:fixed;inset:0;pointer-events:none;z-index:0}
.pg-stars-sm{animation:twinkle-a 3s ease-in-out infinite alternate;box-shadow:42px 38px 0 .5px rgba(255,255,255,.6),310px 24px 0 .5px rgba(255,255,255,.5),520px 62px 0 .5px rgba(255,255,255,.7),680px 88px 0 .5px rgba(255,255,255,.5),920px 42px 0 .5px rgba(255,255,255,.55),1180px 55px 0 .5px rgba(255,255,255,.65),85px 620px 0 .5px rgba(255,255,255,.5),375px 750px 0 .5px rgba(255,255,255,.6),620px 865px 0 .5px rgba(255,255,255,.5),880px 940px 0 .5px rgba(255,255,255,.55),130px 155px 0 .5px rgba(255,210,63,.4),820px 1030px 0 .5px rgba(255,210,63,.4)}
.pg-stars-md{animation:twinkle-b 5s ease-in-out infinite alternate;box-shadow:95px 65px 0 .75px rgba(255,255,255,.65),440px 48px 0 .75px rgba(255,255,255,.7),810px 480px 0 .75px rgba(255,255,255,.55),1130px 890px 0 .75px rgba(255,255,255,.6),60px 1265px 0 .75px rgba(255,255,255,.55),380px 250px 0 .75px rgba(255,255,255,.6)}

.nav{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(10,10,18,.65);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid rgba(123,47,242,.1)}
.nav-inner{max-width:1180px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:72px}
.logo{display:flex;align-items:center;gap:10px;font-weight:800;font-size:1.2rem;z-index:201}
.logo-icon{display:inline-flex;align-items:center;justify-content:center;width:38px;height:38px;background:linear-gradient(135deg,var(--purple),var(--orange));border-radius:11px;font-weight:900;font-size:1.1rem;color:#fff}
.logo-word{color:#fff;letter-spacing:-.3px}
.nav-links{display:flex;align-items:center;gap:28px;font-size:.9rem;font-weight:500}
.nav-links a{color:rgba(255,255,255,.6);transition:color .25s}
.nav-links a:hover,.nav-links a.active{color:#fff}
.burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px;z-index:201}
.burger span{display:block;width:24px;height:2px;background:#fff;border-radius:2px}

.gl-gold,.gl-cyan,.gl-purple,.gl-orange{-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;font-weight:700}
.gl-gold{background-image:linear-gradient(135deg,#FFD23F,#F5C842);filter:drop-shadow(0 0 10px rgba(255,210,63,.3))}
.gl-cyan{background-image:linear-gradient(135deg,#4FD1E8,#38B5CC);filter:drop-shadow(0 0 10px rgba(79,209,232,.3))}
.gl-purple{background-image:linear-gradient(135deg,#7B2FF2,#9B59F0);filter:drop-shadow(0 0 10px rgba(123,47,242,.3))}
.gl-orange{background-image:linear-gradient(135deg,#FF6B35,#FF8F5E);filter:drop-shadow(0 0 10px rgba(255,107,53,.3))}

.page{position:relative;z-index:1;padding:130px 0 80px}

.page-head{margin-bottom:48px}
.eyebrow{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:var(--cyan);margin-bottom:14px}
.page-head h1{font-size:clamp(2rem,4.5vw,3rem);font-weight:900;color:#fff;letter-spacing:-1px;margin-bottom:16px;text-shadow:0 0 50px rgba(123,47,242,.15)}
.page-sub{font-size:1.05rem;color:rgba(255,255,255,.5);max-width:640px;margin-bottom:28px}
.quick-actions{display:flex;gap:12px;flex-wrap:wrap}
.qa-btn{padding:12px 22px;border-radius:12px;font-size:.9rem;font-weight:700;background:var(--glass);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.75);cursor:pointer;transition:transform .3s,box-shadow .3s,border-color .3s}
.qa-btn:hover{transform:translateY(-2px);border-color:rgba(123,47,242,.4);box-shadow:0 0 20px rgba(123,47,242,.15)}
.qa-primary{background:linear-gradient(135deg,var(--purple),var(--orange));color:#fff;border:none;box-shadow:0 0 18px rgba(123,47,242,.3)}
.qa-primary:hover{box-shadow:0 0 30px rgba(123,47,242,.5)}

/* SNAPSHOT */
.snapshot{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:40px}
.snap-card{background:var(--glass);border:1px solid rgba(255,255,255,.06);border-radius:16px;padding:22px;backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);display:flex;flex-direction:column;gap:6px}
.snap-label{font-size:.72rem;text-transform:uppercase;letter-spacing:1px;color:rgba(255,255,255,.4);font-weight:600}
.snap-value{font-size:1.9rem;font-weight:900}
.snap-note{font-size:.78rem;color:rgba(255,255,255,.4)}
.snap-bar{position:relative;height:8px;border-radius:4px;background:rgba(255,255,255,.06);margin-top:6px;overflow:hidden}
.snap-bar-range{position:absolute;top:0;bottom:0;background:rgba(79,209,232,.18);border-radius:4px}
.snap-bar-actual{position:absolute;top:0;bottom:0;left:0;border-radius:4px;background:linear-gradient(90deg,var(--gold),var(--orange))}
.snap-bar-actual.over{background:linear-gradient(90deg,var(--orange),#FF4444)}
.snap-status{justify-content:center}
.snap-status-text{font-size:.95rem;font-weight:600;color:#fff;line-height:1.5}

/* PANELS */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px}
.panel,.panel-full{background:var(--glass);border:1px solid rgba(255,255,255,.06);border-radius:18px;padding:28px;backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px)}
.panel-full{margin-bottom:24px}
.panel-h{font-size:1.1rem;font-weight:800;color:#fff;margin-bottom:20px;letter-spacing:.3px}

/* AI FEED */
.feed-list{display:flex;flex-direction:column;gap:14px}
.feed-item{padding:14px 16px;border-radius:12px;border-left:3px solid transparent;background:rgba(255,255,255,.02)}
.feed-item p{font-size:.88rem;color:rgba(255,255,255,.6);line-height:1.6}
