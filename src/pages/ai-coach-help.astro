		<button class="burger" id="burger" aria-label="Menu">
			<span></span><span></span><span></span>
		</button>
	</div>
</nav>

<!-- MAIN -->
<main class="help-main">
	<div class="container">

		<!-- HERO -->
		<section class="help-hero">
			<div class="hero-badge">AI Coach</div>
			<h1 class="hero-title">AI Coach Help</h1>
			<p class="hero-subtitle">Learn how to use your AI coach to build a saving plan, track income, manage budgeting, and grow investments.</p>
		</section>

		<!-- INTRO -->
		<section class="glass-card intro-card">
			<p class="intro-text">This coach helps you organize your money goals and turn your numbers into a simple plan. Use it to track what you want to save, your active income, extra cash, and how much you can budget each day, week, or month.</p>
		</section>

		<!-- WHAT TO ENTER -->
		<section class="glass-card">
			<div class="section-header">
				<span class="section-icon">📝</span>
				<h2 class="section-title">What to enter</h2>
			</div>
			<div class="entry-grid">
				<div class="entry-item">
					<div class="entry-icon">🎯</div>
					<div class="entry-content">
						<div class="entry-label">Savings goal</div>
						<div class="entry-desc">Enter the amount you want to save up.</div>
					</div>
				</div>
				<div class="entry-item">
					<div class="entry-icon">💵</div>
					<div class="entry-content">
						<div class="entry-label">Income</div>
						<div class="entry-desc">Add your active income, such as paychecks or regular earnings.</div>
					</div>
				</div>
				<div class="entry-item">
					<div class="entry-icon">📅</div>
					<div class="entry-content">
						<div class="entry-label">Pay schedule</div>
						<div class="entry-desc">Choose how often you get paid, or skip if it changes.</div>
					</div>
				</div>
				<div class="entry-item">
					<div class="entry-icon">🗓️</div>
					<div class="entry-content">
						<div class="entry-label">Pay day</div>
						<div class="entry-desc">Enter the day you usually get paid during the week.</div>
					</div>
				</div>
				<div class="entry-item">
					<div class="entry-icon">💰</div>
					<div class="entry-content">
						<div class="entry-label">Average weekly check</div>
						<div class="entry-desc">Add your average weekly paycheck for better results.</div>
					</div>
				</div>
				<div class="entry-item">
					<div class="entry-icon">💸</div>
					<div class="entry-content">
						<div class="entry-label">Extra cash updates</div>
						<div class="entry-desc">Use this option whenever random money comes in.</div>
					</div>
				</div>
				<div class="entry-item">
					<div class="entry-icon">📈</div>
					<div class="entry-content">
						<div class="entry-label">Investing</div>
						<div class="entry-desc">Add money you want the coach to help set aside for investments.</div>
					</div>
				</div>
				<div class="entry-item">
					<div class="entry-icon">📊</div>
					<div class="entry-content">
						<div class="entry-label">Budgeting</div>
						<div class="entry-desc">Add monthly, weekly, or daily spending limits.</div>
					</div>
				</div>
			</div>
		</section>

		<!-- HOW THE COACH HELPS -->
		<section class="glass-card">
			<div class="section-header">
				<span class="section-icon">🧠</span>
				<h2 class="section-title">How the coach helps</h2>
			</div>
			<div class="help-list">
				<div class="help-item">
					<div class="help-check">&#10003;</div>
					<span>Builds a plan based on your goal and income.</span>
				</div>
				<div class="help-item">
					<div class="help-check">&#10003;</div>
					<span>Helps you divide money between saving, spending, and investing.</span>
				</div>
				<div class="help-item">
					<div class="help-check">&#10003;</div>
					<span>Adjusts for irregular income or extra cash.</span>
				</div>
				<div class="help-item">
					<div class="help-check">&#10003;</div>
					<span>Gives budgeting guidance based on your real numbers.</span>
				</div>
				<div class="help-item">
					<div class="help-check">&#10003;</div>
					<span>Helps you stay on track with a simple money roadmap.</span>
				</div>
			</div>
		</section>

		<!-- EXAMPLE PROMPT -->
		<section class="glass-card prompt-card">
			<div class="section-header">
				<span class="section-icon">💬</span>
				<h2 class="section-title">Example prompt</h2>
			</div>
			<div class="prompt-box">
				<p>"Help me plan my money. I want to save <span class="placeholder">[amount]</span>, I get paid <span class="placeholder">[weekly/biweekly/monthly]</span>, my average check is <span class="placeholder">[amount]</span>, my pay day is <span class="placeholder">[day]</span>, I sometimes get extra cash, and I want help with budgeting and investing."</p>
			</div>
		</section>

		<!-- BUTTON LABELS -->
		<section class="glass-card">
			<div class="section-header">
				<span class="section-icon">🔘</span>
				<h2 class="section-title">Quick actions</h2>
			</div>
			<div class="button-grid">
				<div class="action-btn">Save Goal</div>
				<div class="action-btn">Add Income</div>
				<div class="action-btn">Update Extra Cash</div>
				<div class="action-btn accent">Start AI Coach</div>
				<div class="action-btn gold">View Money Plan</div>
			</div>
		</section>

		<!-- SHORT ONBOARDING -->
		<section class="glass-card onboarding-card">
			<div class="onboarding-badge">Quick Start</div>
			<h2 class="onboarding-title">Welcome to your money coach</h2>
			<p class="onboarding-intro">Set your savings goal, income, pay schedule, and extra cash so the coach can help you budget, save, and invest.</p>

			<div class="onboarding-columns">
				<div class="onboarding-col">
					<div class="onboarding-col-title">What to enter</div>
					<ul class="onboarding-list">
						<li>Savings goal</li>
						<li>Income</li>
						<li>Pay frequency</li>
						<li>Pay day</li>
						<li>Average weekly check</li>
						<li>Extra cash updates</li>
						<li>Investing amount</li>
						<li>Budget limits</li>
					</ul>
				</div>
				<div class="onboarding-col">
					<div class="onboarding-col-title">How it works</div>
					<ul class="onboarding-list accent-list">
						<li>Build a savings plan</li>
						<li>Track active income</li>
						<li>Adjust for random cash</li>
						<li>Organize budgeting</li>
						<li>Support investing goals</li>
					</ul>
				</div>
			</div>

			<div class="onboarding-example">
				<div class="onboarding-example-label">Example</div>
				<p>Help me plan my money. I want to save <span class="placeholder">[amount]</span>, I get paid <span class="placeholder">[frequency]</span>, my average check is <span class="placeholder">[amount]</span>, I get paid on <span class="placeholder">[day]</span>, and I want help with budgeting and investing.</p>
			</div>

			<a href="/ai-money-coach" class="cta-btn">Launch AI Coach</a>
		</section>

	</div>
</main>

<!-- FOOTER -->
<footer class="footer">
	<div class="container">
		<p class="footer-copy">&copy; 2026 Financial Literacy Extraordinaire. All rights reserved.</p>
		<div class="footer-links">
			<a href="/">Home</a><span class="footer-dot"></span>
			<a href="/about">About</a><span class="footer-dot"></span>
			<a href="/#features">Features</a><span class="footer-dot"></span>
			<a href="/#faq">Contact</a>
		</div>
		<p class="footer-tagline">Club FLE — Master Your Money. Build Your Future.</p>
	</div>
</footer>

<script>
	document.getElementById('burger')?.addEventListener('click', () => {
		document.getElementById('navLinks')?.classList.toggle('open');
	});
</script>

</body>
</html>

<style>
:root{
	--bg:#0A0A12;--purple:#7B2FF2;--orange:#FF6B35;--gold:#FFD23F;--cyan:#4FD1E8;
	--font:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:var(--font);color:#D8D8E8;background:var(--bg);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{text-decoration:none;color:inherit}
.container{max-width:820px;margin:0 auto;padding:0 24px}

@keyframes twinkle-a{0%{opacity:.3}100%{opacity:.9}}
@keyframes twinkle-b{0%{opacity:.85}100%{opacity:.3}}
@keyframes grid-crawl{0%{background-position:0 0}100%{background-position:60px 60px}}

.grid-bg{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(123,47,242,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(123,47,242,.03) 1px,transparent 1px);background-size:60px 60px;animation:grid-crawl 22s linear infinite}
.pg-stars{position:fixed;inset:0;pointer-events:none;z-index:0}
.pg-stars-sm{animation:twinkle-a 3s ease-in-out infinite alternate;box-shadow:42px 38px 0 .5px rgba(255,255,255,.7),310px 24px 0 .5px rgba(255,255,255,.6),520px 62px 0 .5px rgba(255,255,255,.8),680px 88px 0 .5px rgba(255,255,255,.55),920px 42px 0 .5px rgba(255,255,255,.65),85px 320px 0 .5px rgba(255,255,255,.6),375px 350px 0 .5px rgba(255,255,255,.7)}
.pg-stars-md{animation:twinkle-b 5s ease-in-out infinite alternate;box-shadow:95px 65px 0 .75px rgba(255,255,255,.75),440px 48px 0 .75px rgba(255,255,255,.8),810px 80px 0 .75px rgba(255,255,255,.65),380px 250px 0 .75px rgba(255,255,255,.7),720px 410px 0 .75px rgba(255,255,255,.75)}

.nav{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(10,10,18,.65);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid rgba(123,47,242,.1)}
.nav-inner{max-width:1180px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:72px}
.logo{display:flex;align-items:center;gap:10px;font-weight:800;font-size:1.2rem;z-index:201}
.logo-icon{display:inline-flex;align-items:center;justify-content:center;width:38px;height:38px;background:linear-gradient(135deg,var(--purple),var(--orange));border-radius:11px;font-weight:900;font-size:1.1rem;color:#fff}
.logo-word{color:#fff;letter-spacing:-.3px}
.nav-links{display:flex;align-items:center;gap:24px;font-size:.85rem;font-weight:500}
.nav-links a{color:rgba(255,255,255,.6);transition:color .25s}
.nav-links a:hover,.nav-links a.active{color:#fff}
.nav-btn{background:linear-gradient(135deg,var(--purple),var(--orange));color:#fff!important;padding:10px 24px;border-radius:10px;font-weight:700;transition:transform .3s,box-shadow .3s;box-shadow:0 0 18px rgba(123,47,242,.3)}
.nav-btn:hover{transform:translateY(-2px) scale(1.05);box-shadow:0 0 30px rgba(123,47,242,.5)}
.burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px;z-index:201}
.burger span{display:block;width:24px;height:2px;background:#fff;border-radius:2px}

.help-main{position:relative;z-index:1;padding:100px 0 60px;min-height:80vh}

/* HERO */
.help-hero{text-align:center;margin-bottom:40px}
.hero-badge{display:inline-block;font-size:11px;font-weight:700;letter-spacing:3px;color:#b47aff;text-transform:uppercase;margin-bottom:12px;padding:6px 16px;border-radius:20px;background:rgba(180,122,255,0.1);border:1px solid rgba(180,122,255,0.2)}
.hero-title{font-size:36px;font-weight:800;margin:0 0 12px;background:linear-gradient(135deg,#e0c3ff,#f59e0b,#fbbf24);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hero-subtitle{font-size:16px;color:rgba(255,255,255,.5);max-width:520px;margin:0 auto;line-height:1.7}

/* GLASS CARDS */
.glass-card{background:rgba(18,10,32,0.65);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border:1px solid rgba(160,120,255,0.15);border-radius:16px;padding:28px;margin-bottom:20px;box-shadow:0 4px 24px rgba(0,0,0,0.3),inset 0 1px 0 rgba(255,255,255,0.04)}

/* INTRO */
.intro-card{border-left:3px solid #b47aff}
.intro-text{margin:0;font-size:15px;color:rgba(255,255,255,.7);line-height:1.8}

/* SECTION HEADERS */
.section-header{display:flex;align-items:center;gap:12px;margin-bottom:20px}
.section-icon{font-size:22px}
.section-title{font-size:18px;font-weight:800;color:#e0c3ff;margin:0}

/* ENTRY GRID */
.entry-grid{display:flex;flex-direction:column;gap:12px}
.entry-item{display:flex;align-items:flex-start;gap:14px;padding:14px 18px;border-radius:12px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);transition:border-color 0.25s}
.entry-item:hover{border-color:rgba(180,122,255,0.25)}
.entry-icon{font-size:22px;margin-top:1px;flex-shrink:0}
.entry-content{flex:1}
.entry-label{font-size:14px;font-weight:700;color:rgba(255,255,255,.9);margin-bottom:3px}
.entry-desc{font-size:13px;color:rgba(255,255,255,.45);line-height:1.5}

/* HELP LIST */
.help-list{display:flex;flex-direction:column;gap:10px}
.help-item{display:flex;align-items:center;gap:14px;padding:12px 18px;border-radius:12px;background:rgba(74,222,128,0.04);border:1px solid rgba(74,222,128,0.1);font-size:14px;color:rgba(255,255,255,.75);line-height:1.5}
.help-check{width:24px;height:24px;border-radius:8px;background:rgba(74,222,128,0.15);border:1px solid rgba(74,222,128,0.3);display:flex;align-items:center;justify-content:center;font-size:13px;color:#4ade80;font-weight:700;flex-shrink:0}

/* PROMPT */
.prompt-box{padding:20px 24px;border-radius:12px;background:rgba(180,122,255,0.06);border:1px solid rgba(180,122,255,0.15)}
.prompt-box p{margin:0;font-size:15px;color:rgba(255,255,255,.7);line-height:1.8;font-style:italic}
.placeholder{color:#fbbf24;font-weight:600;font-style:normal}

/* BUTTON GRID */
.button-grid{display:flex;flex-wrap:wrap;gap:10px}
.action-btn{padding:12px 22px;border-radius:12px;font-size:13px;font-weight:700;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,.65);transition:all 0.25s;cursor:default}
.action-btn.accent{background:rgba(180,122,255,0.15);border-color:rgba(180,122,255,0.3);color:#d4b4ff}
.action-btn.gold{background:linear-gradient(135deg,rgba(245,158,11,0.2),rgba(251,191,36,0.1));border-color:rgba(245,158,11,0.3);color:#fbbf24}

/* ONBOARDING */
.onboarding-card{border:1px solid rgba(245,158,11,0.15);text-align:center}
.onboarding-badge{display:inline-block;font-size:11px;font-weight:700;letter-spacing:2px;color:#fbbf24;text-transform:uppercase;margin-bottom:14px;padding:5px 14px;border-radius:20px;background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.2)}
.onboarding-title{font-size:22px;font-weight:800;color:#e0c3ff;margin:0 0 10px}
.onboarding-intro{font-size:14px;color:rgba(255,255,255,.5);margin:0 0 24px;line-height:1.7;max-width:480px;margin-inline:auto}

.onboarding-columns{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px;text-align:left}
.onboarding-col{padding:18px;border-radius:12px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06)}
.onboarding-col-title{font-size:13px;font-weight:700;color:#d4b4ff;margin-bottom:12px;letter-spacing:0.5px}
.onboarding-list{list-style:none;display:flex;flex-direction:column;gap:8px}
.onboarding-list li{font-size:13px;color:rgba(255,255,255,.55);padding-left:16px;position:relative;line-height:1.4}
.onboarding-list li::before{content:"";position:absolute;left:0;top:7px;width:6px;height:6px;border-radius:50%;background:#b47aff}
.accent-list li::before{background:#4ade80}

.onboarding-example{padding:18px 22px;border-radius:12px;background:rgba(180,122,255,0.06);border:1px solid rgba(180,122,255,0.12);text-align:left;margin-bottom:24px}
.onboarding-example-label{font-size:11px;font-weight:700;color:#b47aff;letter-spacing:1px;text-transform:uppercase;margin-bottom:8px}
.onboarding-example p{margin:0;font-size:13px;color:rgba(255,255,255,.6);line-height:1.7}

.cta-btn{display:inline-block;padding:14px 36px;border-radius:12px;background:linear-gradient(135deg,var(--purple),var(--orange));color:#fff;font-size:15px;font-weight:700;letter-spacing:0.3px;transition:transform 0.3s,box-shadow 0.3s;box-shadow:0 0 20px rgba(123,47,242,0.3)}
.cta-btn:hover{transform:translateY(-2px) scale(1.03);box-shadow:0 0 35px rgba(123,47,242,0.5)}

/* FOOTER */
.footer{position:relative;z-index:1;padding:48px 0;background:var(--bg);border-top:1px solid rgba(123,47,242,.08);text-align:center}
.footer-copy{font-size:.85rem;color:rgba(255,255,255,.3);margin-bottom:16px}
.footer-links{display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:16px;flex-wrap:wrap}
.footer-links a{font-size:.85rem;color:rgba(255,255,255,.4);transition:color .25s}
.footer-links a:hover{color:var(--gold)}
.footer-dot{width:4px;height:4px;border-radius:50%;background:rgba(255,255,255,.15)}
.footer-tagline{font-size:.75rem;color:rgba(255,255,255,.18);letter-spacing:.5px}

@media(max-width:768px){
	.nav-links{position:fixed;inset:0;z-index:200;background:rgba(10,10,18,.97);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);flex-direction:column;justify-content:center;gap:28px;font-size:1.3rem;opacity:0;pointer-events:none;transition:opacity .3s}
	.nav-links.open{opacity:1;pointer-events:auto}
	.burger{display:flex}
	.help-main{padding:88px 0 40px}
	.hero-title{font-size:28px}
	.hero-subtitle{font-size:14px}
	.onboarding-columns{grid-template-columns:1fr}
	.button-grid{flex-direction:column}
	.action-btn{text-align:center}
}
</style>
